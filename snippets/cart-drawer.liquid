{% comment %}
  Renders cart drawer — redesigned, editorial.

  Usage: {% render 'cart-drawer' %}
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer { visibility: hidden; }

  /* ─── Reset the generic Dawn cart drawer styles we don't want ─── */
  cart-drawer .drawer__inner {
    font-family: 'Montserrat', -apple-system, sans-serif;
    background: #FDFBF6 !important;
    padding: 0 !important;
    display: flex;
    flex-direction: column;
  }

  /* Hide old column headers entirely */
  cart-drawer .cart-items thead { display: none; }
  cart-drawer table.cart-items { border: 0; margin: 0; }
  cart-drawer .cart-items tbody { display: block; }
  cart-drawer .cart-items tr.cart-item { display: grid; grid-template-columns: 72px 1fr auto; gap: 16px; padding: 20px 24px; border-bottom: 1px solid #eee3d1; align-items: flex-start; }
  cart-drawer .cart-item__media { padding: 0 !important; width: 72px; height: 72px; }
  cart-drawer .cart-item__media img {
    width: 72px; height: 72px;
    object-fit: cover;
    border-radius: 4px;
    background: #f5efe3;
  }
  cart-drawer .cart-item__details {
    padding: 0 !important;
    display: flex; flex-direction: column;
    gap: 4px;
  }
  cart-drawer .cart-item__details .cart-item__name {
    font-family: 'Montserrat', sans-serif !important;
    font-size: 16px !important;
    font-weight: 700 !important;
    line-height: 1.3;
    color: #1a1a1a !important;
    text-decoration: none !important;
    margin: 0 !important;
  }
  cart-drawer .cart-item__details .product-option {
    font-family: 'Montserrat', sans-serif !important;
    font-size: 12px !important;
    color: #6a6a6a !important;
    letter-spacing: 0 !important;
    text-transform: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  cart-drawer .cart-item__details dl { margin: 2px 0 0; padding: 0; }
  cart-drawer .cart-item__details dl .product-option { display: inline; }
  cart-drawer .cart-item__details dl dt { display: inline; font-weight: 400; color: #6a6a6a; }
  cart-drawer .cart-item__details dl dd { display: inline; margin: 0 8px 0 4px; color: #1a1a1a; }

  /* Quantity + remove column */
  cart-drawer .cart-item__totals { display: none !important; }
  cart-drawer .cart-item__quantity { padding: 0 !important; }
  cart-drawer .cart-item__quantity-wrapper { gap: 10px; align-items: center; flex-direction: row; }
  cart-drawer .cart-item__quantity-wrapper .cart-remove-button { order: -1; }
  cart-drawer .quantity.cart-quantity {
    min-height: 32px;
    border: 1px solid #d8d0c0;
    border-radius: 100px;
    background: #fff;
    display: inline-flex;
    align-items: center;
    width: auto;
  }
  cart-drawer .quantity.cart-quantity::before,
  cart-drawer .quantity.cart-quantity::after { display: none !important; }
  cart-drawer .quantity__button {
    width: 28px; min-width: 28px;
    height: 28px;
    color: #1a1a1a;
  }
  cart-drawer .quantity__button svg { width: 10px; height: 10px; }
  cart-drawer .quantity__input {
    color: #1a1a1a !important;
    font-family: 'Montserrat', sans-serif !important;
    font-size: 13px !important;
    width: 28px !important;
    min-width: 28px !important;
    padding: 0 !important;
  }

  /* Line price — shown inline with item, not in a separate column */
  cart-drawer .el-cart-item-price {
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
    margin-top: 8px;
  }

  cart-drawer .cart-remove-button {
    margin: 0 !important;
    padding: 0 !important;
    min-height: auto !important;
    background: transparent !important;
    color: #9a9a9a !important;
  }
  cart-drawer .cart-remove-button:hover { color: #1a1a1a !important; }
  cart-drawer .cart-remove-button svg { width: 16px; height: 16px; }

  /* ─── Header ─── */
  cart-drawer .el-cart-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 24px 20px;
    border-bottom: 1px solid #eee3d1;
  }
  cart-drawer .el-cart-title {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 26px;
    font-weight: 400;
    color: #1a1a1a;
    margin: 0;
    letter-spacing: -0.01em;
  }
  cart-drawer .el-cart-close {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 1px solid #d8d0c0;
    background: transparent;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer;
    color: #1a1a1a;
    transition: background 0.2s ease;
  }
  cart-drawer .el-cart-close:hover { background: rgba(0,0,0,0.04); }
  cart-drawer .el-cart-close svg { width: 14px; height: 14px; }

  /* ─── Items area ─── */
  cart-drawer cart-drawer-items { flex: 1; overflow-y: auto; }
  cart-drawer .cart__contents { padding: 0; }
  cart-drawer .drawer__contents { padding: 0; }
  cart-drawer .drawer__cart-items-wrapper { padding: 0; }

  /* ─── Upsell ─── */
  cart-drawer .el-cart-upsell {
    padding: 10px 24px 16px;
    background: #f5efe3;
    border-top: 1px solid #eee3d1;
  }
  cart-drawer .el-cart-upsell-title {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 17px;
    font-style: italic;
    color: #1a1a1a;
    margin: 0 0 12px;
    font-weight: 400;
  }
  cart-drawer .el-upsell-card {
    position: relative;
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 16px;
    align-items: center;
    width: 100%;
    background: #fff;
    border: 1px solid #eee3d1;
    border-radius: 8px;
    padding: 12px 18px 12px 14px;
    cursor: pointer;
    text-align: left;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
    appearance: none;
    font-family: inherit;
  }
  cart-drawer .el-upsell-card + .el-upsell-card { margin-top: 10px; }
  cart-drawer .el-upsell-card:hover {
    border-color: #d8d0c0;
    box-shadow: 0 2px 6px rgba(0,0,0,0.04);
  }
  cart-drawer .el-upsell-card:active { transform: scale(0.995); }
  cart-drawer .el-upsell-card[disabled] { opacity: 0.5; cursor: not-allowed; }

  /* Left accent: always visible — gold band */
  cart-drawer .el-upsell-card::before {
    content: "";
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 5px;
    background: #C9A646;
  }
  /* Right accent: appears when product is in cart */
  cart-drawer .el-upsell-card::after {
    content: "";
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 5px;
    background: #C9A646;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  cart-drawer .el-upsell-card.is-selected::after { opacity: 1; }
  cart-drawer .el-upsell-card.is-selected { border-color: #d8d0c0; }

  cart-drawer .el-upsell-img {
    width: 64px; height: 64px;
    object-fit: contain;
    border-radius: 4px;
    background: #fff;
    display: block;
  }
  cart-drawer .el-upsell-text { min-width: 0; }
  cart-drawer .el-upsell-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.25;
    margin: 0;
    display: block;
  }
  cart-drawer .el-upsell-price {
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: #1a1a1a;
    white-space: nowrap;
    padding-left: 8px;
  }
  cart-drawer .el-upsell-card.is-loading {
    opacity: 0.7;
    pointer-events: none;
  }

  /* ─── Footer ─── */
  cart-drawer .drawer__footer {
    padding: 20px 24px 24px;
    border-top: 1px solid #eee3d1;
    background: #FDFBF6;
  }
  cart-drawer .el-cart-subtotal {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 16px;
  }
  cart-drawer .el-cart-subtotal-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: 0;
    text-transform: none;
  }
  cart-drawer .el-cart-subtotal-value {
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
  }
  cart-drawer .el-cart-checkout {
    display: block;
    width: 100%;
    padding: 16px 24px;
    background: #1a1a1a;
    color: #FDFBF6;
    border: 0;
    border-radius: 4px;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease;
    text-align: center;
  }
  cart-drawer .el-cart-checkout:hover:not(:disabled) { background: #000; }
  cart-drawer .el-cart-checkout:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ─── Payment icons ─── */
  cart-drawer .el-cart-payment-icons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    margin-top: 14px;
  }
  cart-drawer .el-cart-payment-icons svg {
    height: 22px;
    width: auto;
    display: block;
  }

  /* ─── Trust bar ─── */
  cart-drawer .el-cart-trust {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #eee3d1;
  }
  cart-drawer .el-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1;
    text-align: center;
  }
  cart-drawer .el-trust-item svg {
    width: 20px;
    height: 20px;
    color: #1a1a1a;
    flex-shrink: 0;
  }
  cart-drawer .el-trust-item span {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.3;
  }

  /* ─── Left border: dark emerald — single solid band ─── */
  /* Strip ALL borders off drawer__inner (they were creating a second line) */
  cart-drawer .drawer__inner {
    border: none !important;
  }
  /* Single source of truth: left border on the outer #CartDrawer wrapper */
  cart-drawer #CartDrawer {
    border-left: 4px solid #0D3B2E;
    box-sizing: border-box;
  }

  /* ─── iDEAL + Wero: white background instead of brand colour ─── */
  cart-drawer .el-cart-payment-icons .payment-icon--ideal,
  cart-drawer .el-cart-payment-icons .payment-icon--wero,
  cart-drawer .el-cart-payment-icons [class*="ideal"],
  cart-drawer .el-cart-payment-icons [class*="wero"] {
    background: #fff !important;
    border-radius: 4px;
  }
  cart-drawer .el-cart-payment-icons .payment-icon--ideal rect:first-child,
  cart-drawer .el-cart-payment-icons .payment-icon--wero rect:first-child,
  cart-drawer .el-cart-payment-icons [class*="ideal"] rect:first-child,
  cart-drawer .el-cart-payment-icons [class*="wero"] rect:first-child {
    fill: #fff !important;
  }

  /* Hide stock/tax noise */
  cart-drawer .tax-note,
  cart-drawer small.tax-note,
  cart-drawer .caption-with-letter-spacing { display: none !important; }

  /* Empty state */
  cart-drawer .drawer__inner-empty {
    padding: 60px 24px;
    text-align: center;
  }
  cart-drawer .cart__empty-text {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 24px;
    font-weight: 400;
    color: #1a1a1a;
    margin: 0 0 20px;
  }
  cart-drawer .drawer__inner-empty .button {
    display: inline-block;
    padding: 14px 28px;
    background: #1a1a1a;
    color: #FDFBF6;
    border-radius: 4px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
  }

  /* Hide the duplicate close button from empty state that ships with Dawn */
  cart-drawer .drawer__inner-empty .drawer__close { display: none !important; }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >

      {%- comment -%} ─── HEADER ─── {%- endcomment -%}
      <div class="el-cart-header">
        <h2 class="el-cart-title">{{ 'sections.cart.title' | t | default: 'Cart' }}</h2>
        <button
          type="button"
          class="el-cart-close"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M6 6L18 18M18 6L6 18" />
          </svg>
        </button>
      </div>

      {%- comment -%} ─── EMPTY STATE ─── {%- endcomment -%}
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <h3 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h3>
          <a href="{{ routes.all_products_collection_url }}" class="button">
            {{ 'general.continue_shopping' | t }}
          </a>
        </div>
      {%- endif -%}

      {%- comment -%} ─── ITEMS ─── {%- endcomment -%}
      <cart-drawer-items {% if cart == empty %}class="is-empty"{% endif %}>
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              <div class="drawer__cart-items-wrapper">
                <table class="cart-items" role="table">
                  <thead role="rowgroup">
                    <tr role="row">
                      <th id="CartDrawer-ColumnProductImage" role="columnheader"><span class="visually-hidden">Image</span></th>
                      <th id="CartDrawer-ColumnProduct" scope="col" role="columnheader"><span class="visually-hidden">Product</span></th>
                      <th id="CartDrawer-ColumnTotal" scope="col" role="columnheader"><span class="visually-hidden">Total</span></th>
                      <th id="CartDrawer-ColumnQuantity" role="columnheader"><span class="visually-hidden">Quantity</span></th>
                    </tr>
                  </thead>

                  <tbody role="rowgroup">
                    {%- for item in cart.items -%}
                      <tr
                        id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                        class="cart-item{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
                        role="row"
                      >
                        <td class="cart-item__media" role="cell" headers="CartDrawer-ColumnProductImage">
                          {% if item.image %}
                            <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>
                            <img
                              class="cart-item__image"
                              src="{{ item.image | image_url: width: 200 }}"
                              alt="{{ item.image.alt | escape }}"
                              loading="lazy"
                              width="72"
                              height="72"
                            >
                          {% endif %}
                        </td>

                        <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                          <a href="{{ item.url }}" class="cart-item__name break">
                            {{- item.product.title | escape -}}
                          </a>

                          {%- if item.product.has_only_default_variant == false -%}
                            <dl>
                              {%- for option in item.options_with_values -%}
                                <div class="product-option">
                                  <dt>{{ option.name }}:</dt>
                                  <dd>{{ option.value }}{%- unless forloop.last %}, {% endunless %}</dd>
                                </div>
                              {%- endfor -%}
                            </dl>
                          {%- endif -%}

                          {%- if item.selling_plan_allocation != null -%}
                            <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                          {%- endif -%}

                          <span class="el-cart-item-price">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <s style="color:#9a9a9a; margin-right:6px;">{{ item.original_line_price | money }}</s>
                              {{ item.final_line_price | money }}
                            {%- else -%}
                              {{ item.original_line_price | money }}
                            {%- endif -%}
                          </span>
                        </td>

                        {%- comment -%} Invisible total cell (kept for Dawn's cart.js DOM assumptions) {%- endcomment -%}
                        <td class="cart-item__totals right" role="cell" headers="CartDrawer-ColumnTotal">
                          {%- render 'loading-spinner' -%}
                          <div class="cart-item__price-wrapper">
                            <span class="price price--end">{{ item.original_line_price | money }}</span>
                          </div>
                        </td>

                        <td class="cart-item__quantity" role="cell" headers="CartDrawer-ColumnQuantity">
                          <quantity-popover>
                            <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                              <div class="quantity-popover-container">
                                <quantity-input class="quantity cart-quantity">
                                  <button class="quantity__button" name="minus" type="button">
                                    <span class="visually-hidden">Decrease</span>
                                    <span class="svg-wrapper">{{- 'icon-minus.svg' | inline_asset_content -}}</span>
                                  </button>
                                  <input
                                    class="quantity__input"
                                    type="number"
                                    data-quantity-variant-id="{{ item.variant.id }}"
                                    name="updates[]"
                                    value="{{ item.quantity }}"
                                    data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                    min="0"
                                    data-min="{{ item.variant.quantity_rule.min }}"
                                    {% if item.variant.quantity_rule.max != null %}max="{{ item.variant.quantity_rule.max }}"{% endif %}
                                    step="{{ item.variant.quantity_rule.increment }}"
                                    aria-label="Quantity"
                                    id="Drawer-quantity-{{ item.index | plus: 1 }}"
                                    data-index="{{ item.index | plus: 1 }}"
                                  >
                                  <button class="quantity__button" name="plus" type="button">
                                    <span class="visually-hidden">Increase</span>
                                    <span class="svg-wrapper">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
                                  </button>
                                </quantity-input>
                              </div>
                              <cart-remove-button
                                id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}"
                              >
                                <button
                                  type="button"
                                  class="button button--tertiary cart-remove-button"
                                  aria-label="Remove"
                                  data-variant-id="{{ item.variant.id }}"
                                >
                                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M3 6h18" />
                                    <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                    <path d="M10 11v6" />
                                    <path d="M14 11v6" />
                                  </svg>
                                </button>
                              </cart-remove-button>
                            </div>
                            <div id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}" class="cart-item__error" role="alert">
                              <small class="cart-item__error-text"></small>
                            </div>
                          </quantity-popover>
                        </td>
                      </tr>
                    {%- endfor -%}
                  </tbody>
                </table>
              </div>
            {%- endif -%}
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>

      {%- comment -%} ─── UPSELL (glass etc.) ─── {%- endcomment -%}
      {%- if cart != empty and settings.cart_drawer_collection != blank and settings.cart_drawer_collection.products_count > 0 -%}
        <div class="el-cart-upsell">
          <p class="el-cart-upsell-title">Extra options</p>
          {%- for up_product in settings.cart_drawer_collection.products limit: 2 -%}
            {%- assign up_variant = up_product.selected_or_first_available_variant -%}
            {%- assign up_in_cart = false -%}
            {%- for ci in cart.items -%}
              {%- if ci.variant.id == up_variant.id -%}
                {%- assign up_in_cart = true -%}
              {%- endif -%}
            {%- endfor -%}
            <button
              type="button"
              class="el-upsell-card{% if up_in_cart %} is-selected{% endif %}"
              data-variant-id="{{ up_variant.id }}"
              aria-pressed="{% if up_in_cart %}true{% else %}false{% endif %}"
              {% unless up_variant.available %}disabled{% endunless %}
            >
              {% if up_product.featured_image %}
                <img class="el-upsell-img" src="{{ up_product.featured_image | image_url: width: 160 }}" alt="{{ up_product.featured_image.alt | escape }}" loading="lazy" width="64" height="64">
              {% else %}
                <span class="el-upsell-img"></span>
              {% endif %}
              <div class="el-upsell-text">
                <span class="el-upsell-name">{{ up_product.title | escape }}</span>
              </div>
              <span class="el-upsell-price">
                {%- if up_variant.available -%}
                  {{ up_variant.price | money }}
                {%- else -%}
                  Sold out
                {%- endif -%}
              </span>
            </button>
          {%- endfor -%}
        </div>

        <script>
          (function() {
            var drawer = document.currentScript.closest('cart-drawer');
            if (!drawer || drawer.__elUpsellBound) return;
            drawer.__elUpsellBound = true;
            drawer.addEventListener('click', function(e) {
              var card = e.target.closest('.el-upsell-card');
              if (!card || card.disabled || card.classList.contains('is-loading')) return;
              if (card.classList.contains('is-selected')) return; // already in cart
              e.preventDefault();
              var variantId = card.getAttribute('data-variant-id');
              card.classList.add('is-loading');

              var sectionsToRender = ['cart-drawer', 'cart-icon-bubble'];
              fetch('{{ routes.cart_add_url }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({
                  items: [{ id: variantId, quantity: 1 }],
                  sections: sectionsToRender.join(','),
                  sections_url: window.location.pathname
                })
              })
              .then(function(r) { return r.json(); })
              .then(function(data) {
                if (data.status) {
                  card.classList.remove('is-loading');
                  return;
                }
                var cd = document.querySelector('cart-drawer');
                if (cd && typeof cd.renderContents === 'function') {
                  cd.renderContents(data);
                } else {
                  window.location.reload();
                }
              })
              .catch(function() {
                card.classList.remove('is-loading');
              });
            });
          })();
        </script>
      {%- endif -%}

      {%- comment -%} ─── FOOTER ─── {%- endcomment -%}
      {%- if cart != empty -%}
        <div class="drawer__footer">
          <div class="el-cart-subtotal">
            <span class="el-cart-subtotal-label">Subtotal</span>
            <span class="el-cart-subtotal-value">{{ cart.total_price | money }}</span>
          </div>

          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="el-cart-checkout"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}disabled{% endif %}
          >
            {{ 'sections.cart.checkout' | t }}
          </button>

          {%- comment -%} Payment icons {%- endcomment -%}
          <div class="el-cart-payment-icons" aria-hidden="true">
            {%- assign excluded_payments = 'american_express,unionpay,shopify_pay,google_pay' | split: ',' -%}
            {%- for type in shop.enabled_payment_types -%}
              {%- unless excluded_payments contains type -%}
                {{ type | payment_type_svg_tag: scale: 1 }}
              {%- endunless -%}
            {%- endfor -%}
          </div>

          {%- comment -%} Trust bar {%- endcomment -%}
          <div class="el-cart-trust">
            <div class="el-trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
              <span>100% secure payment</span>
            </div>
            <div class="el-trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12a9 9 0 1 0 3-6.7"/>
                <path d="M3 4v5h5"/>
              </svg>
              <span>30 day free return</span>
            </div>
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
</cart-drawer>

{%- comment -%}
  ─── GLOBAL ADD-TO-CART INTERCEPTOR ───
  Safety-net: ensures any product-add form opens the cart drawer instead of
  navigating to /cart. Dawn's <product-form> normally handles this, but if
  for any reason it fails to bind (custom sections, third-party blocks,
  etc.) this guarantees the drawer opens.
{%- endcomment -%}
<script>
  (function() {
    if (window.__elCartInterceptorBound) return;
    window.__elCartInterceptorBound = true;

    document.addEventListener('submit', function(evt) {
      var form = evt.target;
      if (!(form instanceof HTMLFormElement)) return;
      // Only intercept Shopify product add-to-cart forms (Dawn marks them with data-type)
      if (form.dataset.type !== 'add-to-cart-form') return;
      // If <product-form> already handled this, evt.defaultPrevented is true → bail
      if (evt.defaultPrevented) return;

      evt.preventDefault();

      var drawer = document.querySelector('cart-drawer');
      var submitBtn = form.querySelector('[type="submit"]');
      var originalDisabled = submitBtn ? submitBtn.disabled : false;
      if (submitBtn) submitBtn.disabled = true;

      var formData = new FormData(form);
      // Ask Shopify to also return the cart-drawer + icon sections so we can re-render
      formData.append('sections', 'cart-drawer,cart-icon-bubble');
      formData.append('sections_url', window.location.pathname);

      fetch('{{ routes.cart_add_url }}.js', {
        method: 'POST',
        headers: { 'Accept': 'application/javascript', 'X-Requested-With': 'XMLHttpRequest' },
        body: formData
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.status) {
            // Error path — fall back to native submit so user sees the error UI
            form.submit();
            return;
          }
          if (drawer && typeof drawer.renderContents === 'function') {
            drawer.renderContents(data);
          } else {
            // No drawer → fall back to navigating to cart page
            window.location.href = '{{ routes.cart_url }}';
          }
        })
        .catch(function() {
          // Network error → let native submit happen
          form.submit();
        })
        .finally(function() {
          if (submitBtn) submitBtn.disabled = originalDisabled;
        });
    }); // bubble phase: product-form's handler runs first; if it called preventDefault we bail
  })();
</script>
