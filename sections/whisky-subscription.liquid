{%- comment -%} ===== STICKY CTA ===== {%- endcomment -%}
<div class="wc-sticky" id="wc-sticky" aria-hidden="true">
  <div class="wc-sticky-label">
    <span class="wc-mono" style="color:rgba(245,239,227,0.55);" id="wc-sticky-from">From &euro;40/mo</span>
    <span style="font-family:'EB Garamond',serif;font-size:20px;font-style:italic;">Join the Club</span>
  </div>
  <div class="wc-sticky-sub">
    <div class="wc-sticky-track" id="wc-sticky-track"></div>
    <button class="wc-sticky-btn active" data-sticky-billing="monthly">Monthly</button>
    <button class="wc-sticky-btn" data-sticky-billing="annual">Annual</button>
  </div>
  <a href="#plans" id="wc-sticky-cta" class="wc-sticky-cta">Subscribe &rarr;</a>
</div>

<script>
(function() {
  // ---- State ----
  var billing = 'monthly';
  var tier = 'explorer';

  var explorerUrls = {
    monthly: {{ explorer_monthly_url | json }},
    annual:  {{ explorer_annual_url | json }}
  };
  var advancedUrls = {
    monthly: {{ advanced_monthly_url | json }},
    annual:  {{ advanced_annual_url | json }}
  };

  // ---- Price data ----
  var prices = {
    explorer: { monthly: 40, annual: 34 },
    advanced: { monthly: 50, annual: 42 }
  };

  // ---- Elements ----
  var billingTrack  = document.getElementById('wc-billing-track');
  var billingBtns   = document.querySelectorAll('.wc-billing-btn');
  var priceExplorer = document.getElementById('wc-price-explorer');
  var priceAdvanced = document.getElementById('wc-price-advanced');
  var noteExplorer  = document.getElementById('wc-billing-note-explorer');
  var noteAdvanced  = document.getElementById('wc-billing-note-advanced');
  var explorerCta   = document.getElementById('wc-explorer-cta');
  var advancedCta   = document.getElementById('wc-advanced-cta');

  var tierTrack     = document.getElementById('wc-tier-track');
  var tierBtns      = document.querySelectorAll('.wc-tier-btn');
  var tierContents  = document.querySelectorAll('[data-tier-content]');

  var sticky        = document.getElementById('wc-sticky');
  var stickyTrack   = document.getElementById('wc-sticky-track');
  var stickyBtns    = document.querySelectorAll('.wc-sticky-btn');
  var stickyFrom    = document.getElementById('wc-sticky-from');
  var stickyCta     = document.getElementById('wc-sticky-cta');

  var comparePrices = document.querySelectorAll('[data-compare-price]');

  // ---- Billing toggle ----
  function setBilling(b) {
    billing = b;

    // Animate prices
    [priceExplorer, priceAdvanced].forEach(function(el) { if (el) { el.style.opacity = '0'; el.style.transform = 'translateY(-8px)'; } });
    setTimeout(function() {
      if (priceExplorer) priceExplorer.textContent = prices.explorer[billing];
      if (priceAdvanced) priceAdvanced.textContent = prices.advanced[billing];
      [priceExplorer, priceAdvanced].forEach(function(el) { if (el) { el.style.opacity = '1'; el.style.transform = 'translateY(0)'; } });
    }, 200);

    // Billing notes
    if (noteExplorer) noteExplorer.textContent = billing === 'annual'
      ? 'Billed annually \u00b7 \u20ac' + (prices.explorer.annual * 12) + ' / yr'
      : 'Billed monthly \u00b7 cancel any time';
    if (noteAdvanced) noteAdvanced.textContent = billing === 'annual'
      ? 'Billed annually \u00b7 \u20ac' + (prices.advanced.annual * 12) + ' / yr'
      : 'Billed monthly \u00b7 cancel any time';

    // CTA URLs
    if (explorerCta) explorerCta.href = explorerUrls[billing];
    if (advancedCta) advancedCta.href = advancedUrls[billing];

    // Billing toggle track
    if (billingTrack) billingTrack.style.left = billing === 'monthly' ? '4px' : 'calc(50% + 2px)';

    // Billing toggle buttons
    billingBtns.forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.billing === billing);
    });

    // Sticky
    if (stickyTrack) stickyTrack.style.left = billing === 'monthly' ? '3px' : 'calc(50% + 1px)';
    stickyBtns.forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.stickyBilling === billing);
    });
    if (stickyFrom) stickyFrom.textContent = 'From \u20ac' + (billing === 'annual' ? '34' : '40') + '/mo';
    if (stickyCta) stickyCta.href = explorerUrls[billing];

    // Compare table prices
    comparePrices.forEach(function(el) {
      var key = el.dataset.comparePrice; // e.g. "explorer-monthly"
      var parts = key.split('-');
      var pTier = parts[0]; var pBill = parts[1];
      el.style.display = (pBill === billing) ? '' : 'none';
    });
  }

  billingBtns.forEach(function(btn) {
    btn.addEventListener('click', function() { setBilling(btn.dataset.billing); });
  });
  stickyBtns.forEach(function(btn) {
    btn.addEventListener('click', function() { setBilling(btn.dataset.stickyBilling); });
  });

  // ---- Tier (journey) toggle ----
  function setTier(t) {
    tier = t;
    if (tierTrack) tierTrack.style.left = tier === 'explorer' ? '4px' : 'calc(50% + 2px)';
    tierBtns.forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.tier === tier);
    });
    tierContents.forEach(function(el) {
      el.style.display = el.dataset.tierContent === tier ? 'flex' : 'none';
    });
  }

  tierBtns.forEach(function(btn) {
    btn.addEventListener('click', function() { setTier(btn.dataset.tier); });
  });

  // ---- FAQ accordion ----
  document.querySelectorAll('.wc-faq-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.wc-faq-item');
      var isOpen = item.classList.contains('open');
      // Close all
      document.querySelectorAll('.wc-faq-item').forEach(function(i) {
        i.classList.remove('open');
        i.querySelector('.wc-faq-btn').setAttribute('aria-expanded', 'false');
      });
      // Open clicked if was closed
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ---- Sticky CTA scroll ----
  function onScroll() {
    var y = window.scrollY;
    var h = document.body.scrollHeight;
    var show = y > 900 && y < h - window.innerHeight - 400;
    if (sticky) {
      sticky.classList.toggle('visible', show);
      sticky.setAttribute('aria-hidden', show ? 'false' : 'true');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Init
  setBilling('monthly');
  setTier('explorer');
})();
</script>

