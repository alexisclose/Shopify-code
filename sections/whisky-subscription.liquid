{% comment %}
  Whisky Subscription Landing Page
  —————————————————————————————————
  After creating subscription products in Shopify + a subscriptions app,
  paste the checkout URLs into the theme editor settings for this page.
  URLs format: /cart/add?id=VARIANT_ID&selling_plan=SELLING_PLAN_ID
  or simply: /products/PRODUCT-HANDLE
{% endcomment %}

{% assign explorer_monthly_url = section.settings.explorer_monthly_url | default: '#plans' %}
{% assign explorer_annual_url   = section.settings.explorer_annual_url   | default: '#plans' %}
{% assign advanced_monthly_url  = section.settings.advanced_monthly_url  | default: '#plans' %}
{% assign advanced_annual_url   = section.settings.advanced_annual_url   | default: '#plans' %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
/* ============================================================
   Whisky Club — scoped to .wc
   ============================================================ */
.wc {
  --wc-bg:          #f5efe3;
  --wc-bg-alt:      #ebe2cf;
  --wc-surface:     #fcf9f2;
  --wc-ink:         #1a1814;
  --wc-ink-soft:    #4a4538;
  --wc-ink-mute:    #7a7362;
  --wc-rule:        rgba(26,24,20,0.14);
  --wc-rule-strong: rgba(26,24,20,0.35);
  --wc-accent:      #2d4f8a;
  --wc-accent-ink:  #fcf9f2;
  --wc-paper:       #fcf9f2;
  --wc-hero-bg:     #1f1c17;
  --wc-hero-ink:    #f5efe3;
  --wc-hero-accent: #c49a4d;
  --wc-ph-a:        rgba(26,24,20,0.05);
  --wc-ph-b:        rgba(26,24,20,0.12);

  font-family: 'Montserrat', system-ui, sans-serif;
  font-weight: 400;
  background: var(--wc-bg);
  color: var(--wc-ink);
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
}

.wc *, .wc *::before, .wc *::after { box-sizing: border-box; }

.wc h1, .wc h2, .wc h3, .wc h4 {
  font-family: 'EB Garamond', Georgia, serif;
  font-weight: 500;
  letter-spacing: -0.01em;
  line-height: 1.08;
  margin: 0;
  color: var(--wc-ink);
}
.wc p { margin: 0; }
.wc a { cursor: pointer; }
.wc button { font-family: inherit; cursor: pointer; }

.wc-mono {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}
.wc-eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--wc-ink-mute);
}

.wc-ph {
  background: repeating-linear-gradient(135deg, var(--wc-ph-a) 0 10px, var(--wc-ph-b) 10px 20px);
  display: flex; align-items: center; justify-content: center;
  color: var(--wc-ink-mute);
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: 0.18em;
  text-transform: uppercase; text-align: center;
  padding: 1.5rem;
}

.wc-container { max-width: 1320px; margin: 0 auto; padding: 0 40px; }

/* ---- HERO ---- */
.wc-hero {
  background: var(--wc-hero-bg);
  color: var(--wc-hero-ink);
  padding: 120px 0 100px;
  position: relative; overflow: hidden;
}
.wc-hero-grid {
  display: grid; grid-template-columns: 1.2fr 1fr; gap: 80px; align-items: center;
}
.wc-hero h1 {
  color: var(--wc-hero-ink);
  font-size: clamp(44px, 5.6vw, 88px);
  letter-spacing: -0.02em;
  max-width: 16ch; margin-bottom: 32px;
}
.wc-hero-media {
  position: relative; height: 560px;
  border: 1px solid rgba(255,255,255,0.1);
  background: repeating-linear-gradient(135deg, rgba(255,255,255,0.02) 0 10px, rgba(255,255,255,0.05) 10px 20px);
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.4);
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; letter-spacing: 0.18em;
  text-transform: uppercase; text-align: center;
}
.wc-hero-stamp {
  position: absolute; top: -20px; right: -20px;
  width: 140px; height: 140px; border-radius: 50%;
  border: 1px solid var(--wc-hero-accent);
  display: flex; align-items: center; justify-content: center;
  color: var(--wc-hero-accent);
  font-family: 'EB Garamond', serif; font-style: italic; font-size: 18px;
  transform: rotate(-12deg);
  background: var(--wc-hero-bg);
  text-align: center; line-height: 1.1;
}
.wc-hero-stamp .big { font-size: 32px; font-weight: 500; display: block; }
.wc-hero-stamp .sub {
  font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
  font-family: 'JetBrains Mono', monospace; font-style: normal; display: block;
}
.wc-btn-primary {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 18px 32px;
  background: var(--wc-hero-accent); color: #1a1814;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase;
  border-radius: 100px; text-decoration: none; font-weight: 500; border: 0;
}
.wc-btn-ghost {
  color: var(--wc-hero-ink);
  text-decoration: underline; text-decoration-color: var(--wc-hero-accent);
  text-underline-offset: 6px; font-size: 13px;
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: 0.1em; text-transform: uppercase;
}
.wc-hero-stats {
  margin-top: 100px; padding-top: 40px;
  border-top: 1px solid rgba(255,255,255,0.1);
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px;
}
.wc-hero-stat-n {
  font-family: 'EB Garamond', serif; font-size: 36px;
  letter-spacing: -0.01em; color: var(--wc-hero-ink);
}
.wc-hero-stat-l { color: rgba(255,255,255,0.5); margin-top: 8px; }

/* ---- BILLING TOGGLE ---- */
.wc-billing-toggle {
  display: inline-flex; padding: 4px; border-radius: 100px;
  background: var(--wc-bg-alt); border: 1px solid var(--wc-rule);
  position: relative;
}
.wc-billing-track {
  position: absolute; top: 4px; bottom: 4px;
  width: calc(50% - 6px);
  background: var(--wc-ink); border-radius: 100px;
  transition: left 0.35s cubic-bezier(.65,.02,.3,1);
  left: 4px; /* updated by JS */
}
.wc-billing-btn {
  position: relative; background: transparent; border: 0;
  padding: 10px 28px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--wc-ink-soft); transition: color 0.3s ease; font-weight: 500;
}
.wc-billing-btn.active { color: var(--wc-bg); }

/* ---- PLAN CARDS ---- */
.wc-plans-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
.wc-plan {
  border: 1px solid var(--wc-rule);
  padding: 48px 40px;
  display: flex; flex-direction: column;
  position: relative; min-height: 620px;
  background: var(--wc-paper); color: var(--wc-ink);
}
.wc-plan--featured {
  background: var(--wc-ink); color: var(--wc-bg);
  border-color: var(--wc-ink);
}
.wc-plan-badge {
  position: absolute; top: -12px; left: 40px;
  background: var(--wc-accent); color: var(--wc-accent-ink);
  padding: 6px 14px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
}
.wc-plan-icon {
  width: 48px; height: 48px; border-radius: 50%;
  border: 1px solid var(--wc-rule-strong);
  display: flex; align-items: center; justify-content: center;
  font-family: 'EB Garamond', serif; font-style: italic; font-size: 20px;
}
.wc-plan--featured .wc-plan-icon { border-color: rgba(245,239,227,0.3); }
.wc-plan-price-block {
  padding: 24px 0;
  border-top: 1px solid var(--wc-rule);
  border-bottom: 1px solid var(--wc-rule);
  margin-bottom: 32px;
}
.wc-plan--featured .wc-plan-price-block {
  border-color: rgba(245,239,227,0.15);
}
.wc-price-amount {
  font-family: 'EB Garamond', serif; font-size: 72px;
  line-height: 1; letter-spacing: -0.02em; font-weight: 500;
  transition: opacity 0.2s ease, transform 0.2s ease;
}
.wc-plan-features {
  list-style: none; padding: 0; margin: 0 0 40px;
  display: flex; flex-direction: column; gap: 14px;
}
.wc-plan-features li {
  display: flex; gap: 14px; align-items: flex-start;
  font-size: 14px; color: var(--wc-ink-soft);
}
.wc-plan--featured .wc-plan-features li { color: rgba(245,239,227,0.9); }
.wc-plan-features li::before {
  content: '';
  margin-top: 6px; width: 6px; height: 6px;
  border-radius: 50%; background: var(--wc-accent); flex-shrink: 0;
}
.wc-plan--featured .wc-plan-features li::before { background: var(--wc-hero-accent); }
.wc-plan-cta {
  margin-top: auto;
  background: var(--wc-ink); color: var(--wc-bg);
  border: 0; padding: 20px 32px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
  border-radius: 100px; font-weight: 500;
  display: flex; align-items: center; justify-content: space-between;
  text-decoration: none;
}
.wc-plan--featured .wc-plan-cta {
  background: var(--wc-hero-accent); color: #1a1814;
}
.wc-guarantee {
  margin-top: 32px; padding: 20px 32px;
  background: var(--wc-bg-alt); border-left: 2px solid var(--wc-accent);
  display: flex; gap: 24px; align-items: center;
  flex-wrap: wrap; justify-content: space-between;
}

/* ---- HOW IT WORKS ---- */
.wc-how {
  padding: 120px 0;
  background: var(--wc-bg-alt);
  border-top: 1px solid var(--wc-rule); border-bottom: 1px solid var(--wc-rule);
}
.wc-how-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; background: var(--wc-rule-strong);
}
.wc-how-step {
  background: var(--wc-bg-alt); padding: 40px 32px 48px;
  display: flex; flex-direction: column; min-height: 320px;
}
.wc-step-n {
  font-family: 'EB Garamond', serif; font-style: italic;
  font-size: 56px; color: var(--wc-accent); line-height: 1; margin-bottom: 24px;
}

/* ---- JOURNEY / CURRICULUM ---- */
.wc-journey { padding: 140px 0; background: var(--wc-bg); }
.wc-journey-header {
  display: flex; justify-content: space-between; align-items: flex-end;
  margin-bottom: 60px; gap: 40px; flex-wrap: wrap;
}
.wc-tier-toggle {
  display: inline-flex; padding: 4px; border-radius: 100px;
  background: var(--wc-bg-alt); border: 1px solid var(--wc-rule);
  position: relative;
}
.wc-tier-track {
  position: absolute; top: 4px; bottom: 4px;
  width: calc(50% - 6px);
  background: var(--wc-ink); border-radius: 100px;
  transition: left 0.35s cubic-bezier(.65,.02,.3,1);
  left: 4px;
}
.wc-tier-btn {
  position: relative; background: transparent; border: 0;
  padding: 10px 24px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--wc-ink-soft); transition: color 0.3s ease; font-weight: 500;
}
.wc-tier-btn.active { color: var(--wc-bg); }
.wc-curriculum {
  position: relative;
}
.wc-curriculum-line {
  position: absolute; top: 48px; left: 0; right: 0; height: 1px;
  background: var(--wc-rule-strong);
}
.wc-curriculum-grid {
  display: grid; grid-template-columns: repeat(6, 1fr); gap: 20px;
}
.wc-box-dot-row {
  height: 96px; display: flex; align-items: center;
  justify-content: flex-start; position: relative;
}
.wc-box-dot {
  width: 16px; height: 16px; border-radius: 50%;
  background: var(--wc-bg); border: 2px solid var(--wc-rule-strong);
  margin-left: 32px;
}
.wc-box-dot--active {
  background: var(--wc-accent); border-color: var(--wc-accent);
}
.wc-box-start-label {
  position: absolute; top: -24px; left: 24px;
  font-family: 'JetBrains Mono', monospace; font-size: 11px;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--wc-accent); white-space: nowrap;
}
.wc-box-card {
  border: 1px solid var(--wc-rule);
  padding: 24px 22px 28px;
  background: var(--wc-paper);
  min-height: 240px; display: flex; flex-direction: column;
  position: relative; overflow: hidden;
}
.wc-box-card--locked {
  background: transparent;
}
.wc-box-card--locked::after {
  content: '';
  position: absolute; inset: 0;
  background: repeating-linear-gradient(135deg, var(--wc-ph-a) 0 8px, var(--wc-ph-b) 8px 16px);
  opacity: 0.5;
}
.wc-box-card__inner { position: relative; display: flex; flex-direction: column; height: 100%; }
.wc-box-num {
  font-family: 'EB Garamond', serif; font-style: italic;
  font-size: 40px; line-height: 1; color: var(--wc-accent);
}
.wc-box-num--locked { color: var(--wc-ink-mute); }
.wc-box-month {
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  letter-spacing: 0.15em; text-transform: uppercase; color: var(--wc-ink-mute);
}
.wc-box-title { font-size: 20px; margin-bottom: 10px; letter-spacing: -0.01em; }
.wc-box-title--locked { color: var(--wc-ink-mute); font-style: italic; }
.wc-box-hint {
  font-size: 12.5px; color: var(--wc-ink-soft);
  line-height: 1.55; margin: 0; font-style: italic;
}
.wc-box-revealed {
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  letter-spacing: 0.15em; text-transform: uppercase;
  margin-top: auto; padding-top: 16px; color: var(--wc-ink-mute);
}

/* ---- IN THE BOX ---- */
.wc-inbox { padding: 140px 0; background: var(--wc-bg); }
.wc-inbox-grid {
  display: grid; grid-template-columns: 1fr 1.2fr; gap: 100px; align-items: start;
}
.wc-inbox-sticky { position: sticky; top: 100px; }
.wc-inbox-item {
  padding: 36px 0; display: grid; grid-template-columns: 100px 1fr; gap: 32px;
  border-top: 1px solid var(--wc-rule);
}
.wc-inbox-item:first-child { border-top-color: var(--wc-ink); }
.wc-inbox-item:last-child { border-bottom: 1px solid var(--wc-ink); }

/* ---- COMPARISON TABLE ---- */
.wc-compare { padding: 120px 0; background: var(--wc-bg-alt); border-top: 1px solid var(--wc-rule); border-bottom: 1px solid var(--wc-rule); }
.wc-compare-table { border: 1px solid var(--wc-rule-strong); background: var(--wc-paper); }
.wc-compare-head {
  display: grid; grid-template-columns: 1.4fr 1fr 1fr;
  border-bottom: 1px solid var(--wc-rule-strong);
  background: var(--wc-ink); color: var(--wc-bg);
}
.wc-compare-row {
  display: grid; grid-template-columns: 1.4fr 1fr 1fr;
  border-bottom: 1px solid var(--wc-rule); font-size: 14px;
}
.wc-compare-row:last-child { border-bottom: 0; }
.wc-compare-cell { padding: 20px 32px; }
.wc-compare-cell--exp { border-left: 1px solid var(--wc-rule); }
.wc-compare-cell--adv {
  border-left: 1px solid var(--wc-rule);
  background: rgba(196,154,77,0.05);
}
.wc-compare-head .wc-compare-cell--adv { background: rgba(196,154,77,0.12); }
.wc-dot { font-family: 'EB Garamond', serif; font-size: 22px; }
.wc-dash { font-family: 'EB Garamond', serif; font-size: 22px; color: var(--wc-ink-mute); }

/* ---- TESTIMONIALS ---- */
.wc-testimonials { padding: 140px 0; background: var(--wc-bg); }
.wc-testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.wc-quote {
  margin: 0; padding: 40px 36px 36px;
  border: 1px solid var(--wc-rule); background: var(--wc-paper);
  display: flex; flex-direction: column; min-height: 340px;
}
.wc-quote-mark {
  font-family: 'EB Garamond', serif; font-style: italic;
  font-size: 80px; line-height: 0.7; color: var(--wc-accent); margin-bottom: 12px;
}
.wc-quote blockquote {
  margin: 0; font-family: 'EB Garamond', serif;
  font-size: 22px; line-height: 1.35; color: var(--wc-ink); flex: 1;
}
.wc-quote figcaption {
  margin-top: 32px; padding-top: 20px; border-top: 1px solid var(--wc-rule);
  display: flex; justify-content: space-between; align-items: center; font-size: 13px;
}
.wc-tier-tag {
  padding: 4px 10px; border: 1px solid var(--wc-rule-strong); color: var(--wc-ink-soft);
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  letter-spacing: 0.15em; text-transform: uppercase;
}

/* ---- FAQ ---- */
.wc-faq { padding: 120px 0; background: var(--wc-bg-alt); border-top: 1px solid var(--wc-rule); }
.wc-faq-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 80px; align-items: start; }
.wc-faq-sticky { position: sticky; top: 100px; }
.wc-faq-item {
  border-top: 1px solid var(--wc-rule-strong);
}
.wc-faq-item:last-child { border-bottom: 1px solid var(--wc-rule-strong); }
.wc-faq-btn {
  width: 100%; text-align: left; padding: 28px 0;
  background: transparent; border: 0;
  display: flex; justify-content: space-between; align-items: center;
  color: var(--wc-ink);
}
.wc-faq-q { font-family: 'EB Garamond', serif; font-size: 24px; font-weight: 500; }
.wc-faq-icon {
  font-size: 24px; font-family: 'EB Garamond', serif;
  transition: transform 0.3s ease; color: var(--wc-accent); flex-shrink: 0;
}
.wc-faq-item.open .wc-faq-icon { transform: rotate(45deg); }
.wc-faq-body {
  max-height: 0; overflow: hidden; opacity: 0;
  transition: max-height 0.4s ease, opacity 0.3s ease, padding-bottom 0.3s ease;
  padding-bottom: 0;
}
.wc-faq-item.open .wc-faq-body {
  max-height: 300px; opacity: 1; padding-bottom: 28px;
}
.wc-faq-body p { color: var(--wc-ink-soft); font-size: 15px; line-height: 1.7; max-width: 640px; }

/* ---- CLOSING CTA ---- */
.wc-closing {
  padding: 140px 0;
  background: var(--wc-hero-bg); color: var(--wc-hero-ink);
  text-align: center; position: relative; overflow: hidden;
}
.wc-closing h2 {
  color: var(--wc-hero-ink);
  font-size: clamp(48px, 6.5vw, 104px);
  max-width: 14ch; margin: 0 auto 40px; letter-spacing: -0.02em;
}
.wc-closing-cta {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 22px 40px;
  background: var(--wc-hero-accent); color: #1a1814;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase;
  border-radius: 100px; text-decoration: none; font-weight: 600;
}

/* ---- STICKY CTA ---- */
.wc-sticky {
  position: fixed; bottom: 24px; left: 50%;
  transform: translateX(-50%) translateY(120px);
  opacity: 0;
  transition: transform 0.5s cubic-bezier(.65,.02,.3,1), opacity 0.3s ease;
  z-index: 200;
  background: var(--wc-ink); color: var(--wc-bg);
  border-radius: 100px; padding: 10px 10px 10px 28px;
  display: flex; align-items: center; gap: 24px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.25);
  min-width: 520px; pointer-events: none;
}
.wc-sticky.visible {
  transform: translateX(-50%) translateY(0);
  opacity: 1; pointer-events: auto;
}
.wc-sticky-sub {
  display: inline-flex; padding: 3px; border-radius: 100px;
  background: rgba(255,255,255,0.1); position: relative;
}
.wc-sticky-track {
  position: absolute; top: 3px; bottom: 3px;
  width: calc(50% - 4px); background: var(--wc-bg); border-radius: 100px;
  transition: left 0.3s cubic-bezier(.65,.02,.3,1); left: 3px;
}
.wc-sticky-btn {
  position: relative; background: transparent; border: 0;
  padding: 8px 16px;
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: rgba(245,239,227,0.7); transition: color 0.3s ease;
}
.wc-sticky-btn.active { color: var(--wc-ink); }
.wc-sticky-cta {
  background: var(--wc-hero-accent); color: #1a1814;
  border-radius: 100px; padding: 14px 24px;
  font-family: 'JetBrains Mono', monospace; font-size: 11px;
  letter-spacing: 0.15em; text-transform: uppercase;
  text-decoration: none; font-weight: 600;
  display: inline-flex; align-items: center; gap: 8px;
}

/* ---- RESPONSIVE ---- */
@media (max-width: 900px) {
  .wc-container { padding: 0 20px; }
  .wc-hero { padding: 72px 0 64px; }
  .wc-hero-grid { grid-template-columns: 1fr; gap: 48px; }
  .wc-hero h1 { font-size: 44px; }
  .wc-hero-media { height: 360px; }
  .wc-hero-stamp { width: 100px; height: 100px; top: -10px; right: -10px; font-size: 12px; }
  .wc-hero-stamp .big { font-size: 24px; }
  .wc-hero-stats { grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 56px; }
  .wc-plans-grid { grid-template-columns: 1fr; gap: 16px; }
  .wc-how-grid { grid-template-columns: 1fr 1fr; }
  .wc-curriculum-grid {
    grid-template-columns: repeat(6, 260px);
    overflow-x: auto; padding-bottom: 12px;
    scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
  }
  .wc-curriculum-grid > div { scroll-snap-align: start; }
  .wc-inbox-grid { grid-template-columns: 1fr; gap: 40px; }
  .wc-inbox-sticky { position: static; }
  .wc-inbox-item { grid-template-columns: 1fr; gap: 12px; padding: 28px 0; }
  .wc-compare-head { grid-template-columns: 1fr 1fr; }
