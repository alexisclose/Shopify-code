{%- comment -%} ===== STICKY CTA ===== {%- endcomment -%}
<div class="wcp-sticky" id="wcp-sticky" aria-hidden="true">
  <div class="wcp-sticky-label">
    <span class="wcp-sticky-from" id="wcp-sticky-from">From &euro;{{ price_monthly }}/mo</span>
    <span class="wcp-sticky-title">{{ tier_name }} &mdash; Join the Club</span>
  </div>
  <div class="wcp-sticky-toggle">
    <div class="wcp-sticky-track" id="wcp-sticky-track"></div>
    <button class="wcp-sticky-btn active" data-billing="monthly">Monthly</button>
    <button class="wcp-sticky-btn" data-billing="annual">Annual</button>
  </div>
  {%- if product != blank -%}
    <button form="wcp-product-form" type="submit" class="wcp-sticky-cta">Subscribe &rarr;</button>
  {%- else -%}
    <a id="wcp-sticky-link" href="{{ section.settings.monthly_url | default: '#' }}" class="wcp-sticky-cta">Subscribe &rarr;</a>
  {%- endif -%}
</div>

<script>
(function() {
  var billing      = 'monthly';
  var priceMonthly = {{ price_monthly }};
  var priceAnnual  = {{ price_annual }};
  var annualTotal  = {{ annual_total }};
  var monthlyUrl   = {{ section.settings.monthly_url | default: '#' | json }};
  var annualUrl    = {{ section.settings.annual_url  | default: '#' | json }};

  var track       = document.getElementById('wcp-billing-track');
  var priceEl     = document.getElementById('wcp-price');
  var noteEl      = document.getElementById('wcp-price-note');
  var fromEl      = document.getElementById('wcp-sticky-from');
  var stickyTrack = document.getElementById('wcp-sticky-track');
  var link1       = document.getElementById('wcp-subscribe-link');
  var link2       = document.getElementById('wcp-subscribe-link-2');
  var stickyLink  = document.getElementById('wcp-sticky-link');
  var planInput   = document.getElementById('wcp-selling-plan-input');

  function setBilling(b) {
    billing = b;
    var price = b === 'monthly' ? priceMonthly : priceAnnual;

    if (priceEl) {
      priceEl.style.opacity = '0';
      priceEl.style.transform = 'translateY(-10px)';
      setTimeout(function() {
        priceEl.textContent = price;
        priceEl.style.opacity = '1';
        priceEl.style.transform = 'translateY(0)';
      }, 180);
    }

    if (noteEl) noteEl.textContent = b === 'annual'
      ? 'Billed annually \u00b7 \u20ac' + annualTotal + ' / yr'
      : 'Billed monthly \u00b7 cancel any time';
    if (fromEl) fromEl.textContent = 'From \u20ac' + price + '/mo';

    if (track) track.style.left = b === 'monthly' ? '4px' : 'calc(50% + 2px)';
    if (stickyTrack) stickyTrack.style.left = b === 'monthly' ? '3px' : 'calc(50% + 1px)';

    document.querySelectorAll('.wcp-billing-btn, .wcp-sticky-btn').forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.billing === b);
    });

    var url = b === 'monthly' ? monthlyUrl : annualUrl;
    [link1, link2, stickyLink].forEach(function(el) { if (el) el.href = url; });

    if (planInput) {
      var planEl = document.getElementById(b === 'monthly' ? 'wcp-plan-monthly' : 'wcp-plan-annual');
      if (planEl) planInput.value = planEl.dataset.planId;
    }
  }

  document.querySelectorAll('.wcp-billing-btn, .wcp-sticky-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { setBilling(btn.dataset.billing); });
  });

  document.querySelectorAll('.wcp-faq-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.wcp-faq-item');
      var wasOpen = item.classList.contains('open');
      document.querySelectorAll('.wcp-faq-item').forEach(function(i) {
        i.classList.remove('open');
        var b = i.querySelector('.wcp-faq-btn');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
      if (!wasOpen) { item.classList.add('open'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });

  var sticky = document.getElementById('wcp-sticky');
  function onScroll() {
    var y = window.scrollY;
    var show = y > 900 && y < document.body.scrollHeight - window.innerHeight - 400;
    if (sticky) {
      sticky.classList.toggle('visible', show);
      sticky.setAttribute('aria-hidden', show ? 'false' : 'true');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
  setBilling('monthly');
})();
</script>

