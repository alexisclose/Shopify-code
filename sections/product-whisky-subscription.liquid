      <div class="wcp-container">
        <div class="wcp-testimonials-head">
          <div>
            <div class="wcp-eyebrow" style="margin-bottom:16px;">&sect; 05 &mdash; From the members</div>
            <h2>{{ section.settings.testimonials_headline }}</h2>
          </div>
          <div class="wcp-rating-badge">
            <span class="wcp-rating-n">{{ section.settings.rating_value | default: '4.9' }}</span>
            <div>
              <div class="wcp-rating-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              <div class="wcp-mono" style="color:var(--wcp-ink-mute);margin-top:4px;">{{ section.settings.rating_label }}</div>
            </div>
          </div>
        </div>
        <div class="wcp-testimonials-grid">
          {%- for block in testimonial_blocks -%}
            <figure class="wcp-quote" {{ block.shopify_attributes }}>
              <span class="wcp-quote-mark">&ldquo;</span>
              <blockquote>{{ block.settings.quote }}</blockquote>
              <figcaption>
                <div>
                  <div class="wcp-quote-author">{{ block.settings.author }}</div>
                  <div class="wcp-quote-meta">{{ block.settings.meta }}</div>
                </div>
                <div class="wcp-tier-tag">{{ block.settings.tier_label }}</div>
              </figcaption>
            </figure>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== FAQ ===== {%- endcomment -%}
  {%- if faq_blocks.size > 0 -%}
    <section class="wcp-faq" id="faq">
      <div class="wcp-container">
        <div class="wcp-faq-grid">
          <div class="wcp-faq-sticky">
            <div class="wcp-eyebrow" style="margin-bottom:16px;">&sect; 06 &mdash; Fine print</div>
            <h2>{{ section.settings.faq_headline }}</h2>
            <p>{{ section.settings.faq_contact }}</p>
          </div>
          <div>
            {%- for block in faq_blocks -%}
              <div class="wcp-faq-item{% if forloop.first %} open{% endif %}" {{ block.shopify_attributes }}>
                <button class="wcp-faq-btn" aria-expanded="{{ forloop.first }}">
                  <span class="wcp-faq-q">{{ block.settings.question }}</span>
                  <span class="wcp-faq-icon">+</span>
                </button>
                <div class="wcp-faq-body"><p>{{ block.settings.answer }}</p></div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== CLOSING CTA ===== {%- endcomment -%}
