{% comment %}
  Whisky Subscription Product Page
  All text is editable in the Shopify theme editor (Online Store → Customize).
  Blocks: feature, how_step, box_item, faq, testimonial
{% endcomment %}

{%- assign tier = section.settings.tier | default: 'explorer' -%}
{%- assign is_explorer = false -%}
{%- if tier == 'explorer' -%}{%- assign is_explorer = true -%}{%- endif -%}

{%- if is_explorer -%}
  {%- assign tier_name     = 'Explorer' -%}
  {%- assign tier_initial  = 'E' -%}
  {%- assign price_monthly = 40 -%}
  {%- assign price_annual  = 34 -%}
  {%- assign annual_total  = 408 -%}
{%- else -%}
  {%- assign tier_name     = 'Advanced' -%}
  {%- assign tier_initial  = 'A' -%}
  {%- assign price_monthly = 50 -%}
  {%- assign price_annual  = 42 -%}
  {%- assign annual_total  = 504 -%}
{%- endif -%}

{%- assign feature_blocks     = section.blocks | where: "type", "feature" -%}
{%- assign how_blocks         = section.blocks | where: "type", "how_step" -%}
{%- assign box_blocks         = section.blocks | where: "type", "box_item" -%}
{%- assign faq_blocks         = section.blocks | where: "type", "faq" -%}
{%- assign testimonial_blocks = section.blocks | where: "type", "testimonial" -%}

{%- assign other_tier_url = section.settings.other_tier_url | default: '/pages/whisky-club' -%}
{%- assign club_page_url  = section.settings.club_page_url  | default: '/pages/whisky-club' -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
.wcp {
  --wcp-bg:          #f5efe3;
  --wcp-bg-alt:      #ebe2cf;
  --wcp-ink:         #1a1814;
  --wcp-ink-soft:    #4a4538;
  --wcp-ink-mute:    #7a7362;
  --wcp-rule:        rgba(26,24,20,0.14);
  --wcp-rule-strong: rgba(26,24,20,0.35);
  --wcp-accent:      #2d4f8a;
  --wcp-paper:       #fcf9f2;
  --wcp-hero-bg:     #1f1c17;
  --wcp-hero-ink:    #f5efe3;
  --wcp-gold:        #c49a4d;
  --wcp-ph-a:        rgba(26,24,20,0.05);
  --wcp-ph-b:        rgba(26,24,20,0.12);
  font-family: 'Montserrat', system-ui, sans-serif;
  font-weight: 400; background: var(--wcp-bg); color: var(--wcp-ink);
  line-height: 1.55; -webkit-font-smoothing: antialiased;
}
.wcp *, .wcp *::before, .wcp *::after { box-sizing: border-box; }
.wcp h1, .wcp h2, .wcp h3, .wcp h4 {
  font-family: 'EB Garamond', Georgia, serif;
  font-weight: 500; letter-spacing: -0.01em; line-height: 1.08; margin: 0;
}
.wcp p { margin: 0; }
.wcp button { font-family: inherit; cursor: pointer; }
.wcp-mono { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; }
.wcp-eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--wcp-ink-mute); }
.wcp-container { max-width: 1320px; margin: 0 auto; padding: 0 40px; }

/* HERO */
.wcp-hero { background: var(--wcp-hero-bg); color: var(--wcp-hero-ink); padding: 80px 0 100px; }
.wcp-hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
.wcp-hero h1 { color: var(--wcp-hero-ink); font-size: clamp(56px, 6vw, 96px); letter-spacing: -0.02em; font-style: italic; font-weight: 400; margin-bottom: 16px; }
.wcp-hero-subtitle { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--wcp-gold); margin-bottom: 12px; display: block; }
.wcp-billing-wrap { margin: 32px 0 28px; padding: 28px 0; border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1); }
.wcp-billing-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,239,227,0.5); margin-bottom: 16px; }
.wcp-billing-toggle { display: inline-flex; padding: 4px; border-radius: 100px; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.3); position: relative; margin-bottom: 20px; }
.wcp-billing-track { position: absolute; top: 4px; bottom: 4px; left: 4px; width: calc(50% - 6px); background: var(--wcp-hero-ink); border-radius: 100px; transition: left 0.35s cubic-bezier(.65,.02,.3,1); }
.wcp-billing-btn { position: relative; background: transparent; border: 0; padding: 10px 24px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,239,227,0.9); transition: color 0.3s ease; font-weight: 500; }
.wcp-billing-btn.active { color: var(--wcp-ink); }
.wcp-price-row { display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px; }
.wcp-price-currency { font-family: 'EB Garamond', serif; font-size: 28px; color: var(--wcp-hero-ink); }
.wcp-price-amount { font-family: 'EB Garamond', serif; font-size: 80px; line-height: 1; letter-spacing: -0.02em; font-weight: 500; color: var(--wcp-hero-ink); transition: opacity 0.2s ease, transform 0.2s ease; }
.wcp-price-period { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,239,227,0.55); margin-left: 4px; }
.wcp-price-note { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,239,227,0.45); }
.wcp-subscribe-btn { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 22px 32px; background: var(--wcp-gold); color: #1a1814; border: 0; font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; border-radius: 100px; font-weight: 600; transition: opacity 0.2s ease; text-decoration: none; cursor: pointer; }
.wcp-subscribe-btn:hover { opacity: 0.9; }
.wcp-trust { display: flex; gap: 24px; margin-top: 20px; flex-wrap: wrap; }
.wcp-trust-item { display: flex; align-items: center; gap: 8px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,239,227,0.5); }
.wcp-hero-media { position: relative; aspect-ratio: 4/5; background: repeating-linear-gradient(135deg, rgba(255,255,255,0.02) 0 10px, rgba(255,255,255,0.05) 10px 20px); border: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.35); font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; text-align: center; overflow: hidden; }
.wcp-hero-media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.wcp-tier-badge { position: absolute; bottom: 24px; left: 24px; background: var(--wcp-hero-bg); border: 1px solid var(--wcp-gold); padding: 16px 20px; display: flex; align-items: center; gap: 16px; }
.wcp-tier-badge-initial { width: 48px; height: 48px; border-radius: 50%; border: 1px solid var(--wcp-gold); display: flex; align-items: center; justify-content: center; font-family: 'EB Garamond', serif; font-style: italic; font-size: 24px; color: var(--wcp-gold); }

/* FEATURES */
.wcp-features { padding: 100px 0; background: var(--wcp-paper); }
.wcp-features-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
.wcp-feature-list { list-style: none; padding: 0; margin: 32px 0 0; display: flex; flex-direction: column; }
.wcp-feature-item { display: flex; gap: 24px; align-items: flex-start; padding: 20px 0; border-bottom: 1px solid var(--wcp-rule); font-size: 15px; }
.wcp-feature-item:first-child { border-top: 1px solid var(--wcp-ink); }
.wcp-feature-item:last-child { border-bottom-color: var(--wcp-ink); }
.wcp-feature-num { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--wcp-ink-mute); flex-shrink: 0; padding-top: 2px; width: 24px; }
.wcp-feature-text { color: var(--wcp-ink-soft); }

/* HOW IT WORKS */
.wcp-how { padding: 100px 0; background: var(--wcp-bg-alt); border-top: 1px solid var(--wcp-rule); border-bottom: 1px solid var(--wcp-rule); }
.wcp-how-grid { display: grid; gap: 1px; background: var(--wcp-rule-strong); }
.wcp-how-step { background: var(--wcp-bg-alt); padding: 36px 28px 44px; display: flex; flex-direction: column; min-height: 280px; }
.wcp-step-n { font-family: 'EB Garamond', serif; font-style: italic; font-size: 48px; color: var(--wcp-accent); line-height: 1; margin-bottom: 20px; }

/* JOURNEY */
.wcp-journey { padding: 100px 0; background: var(--wcp-paper); }
.wcp-journey-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px; position: relative; margin-top: 60px; }
.wcp-journey-line { position: absolute; top: 48px; left: 0; right: 0; height: 1px; background: var(--wcp-rule-strong); }
.wcp-jbox { display: flex; flex-direction: column; gap: 16px; position: relative; }
.wcp-jdot-row { height: 96px; display: flex; align-items: center; padding-left: 24px; position: relative; }
.wcp-jdot { width: 16px; height: 16px; border-radius: 50%; background: var(--wcp-paper); border: 2px solid var(--wcp-rule-strong); }
.wcp-jdot--active { background: var(--wcp-accent); border-color: var(--wcp-accent); }
.wcp-jstart { position: absolute; top: -24px; left: 16px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--wcp-accent); white-space: nowrap; }
.wcp-jcard { border: 1px solid var(--wcp-rule); padding: 20px 18px 24px; min-height: 220px; display: flex; flex-direction: column; position: relative; overflow: hidden; background: var(--wcp-paper); }
.wcp-jcard--locked { background: transparent; }
.wcp-jcard--locked::after { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(135deg, var(--wcp-ph-a) 0 8px, var(--wcp-ph-b) 8px 16px); opacity: 0.5; }
.wcp-jcard__inner { position: relative; flex: 1; display: flex; flex-direction: column; }
.wcp-jbox-n { font-family: 'EB Garamond', serif; font-style: italic; font-size: 36px; line-height: 1; color: var(--wcp-accent); margin-bottom: 8px; }
.wcp-jbox-n--locked { color: var(--wcp-ink-mute); }
.wcp-jbox-mo { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--wcp-ink-mute); }
.wcp-jbox-title { font-size: 17px; margin: 8px 0 6px; letter-spacing: -0.01em; font-family: 'EB Garamond', serif; }
.wcp-jbox-title--locked { color: var(--wcp-ink-mute); font-style: italic; }
.wcp-jbox-hint { font-size: 12px; color: var(--wcp-ink-soft); line-height: 1.5; font-style: italic; }
.wcp-jbox-sealed { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; margin-top: auto; padding-top: 12px; color: var(--wcp-ink-mute); }

/* IN THE BOX */
.wcp-inbox { padding: 100px 0; background: var(--wcp-bg-alt); border-top: 1px solid var(--wcp-rule); }
.wcp-inbox-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 80px; align-items: start; }
.wcp-inbox-sticky { position: sticky; top: 100px; }
.wcp-inbox-item { padding: 32px 0; display: grid; grid-template-columns: 80px 1fr; gap: 28px; border-top: 1px solid var(--wcp-rule); }
.wcp-inbox-item:first-child { border-top-color: var(--wcp-ink); }
.wcp-inbox-item:last-child { border-bottom: 1px solid var(--wcp-ink); }

/* FAQ */
.wcp-faq { padding: 100px 0; background: var(--wcp-paper); border-top: 1px solid var(--wcp-rule); }
.wcp-faq-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 80px; align-items: start; }
.wcp-faq-sticky { position: sticky; top: 100px; }
.wcp-faq-item { border-top: 1px solid var(--wcp-rule-strong); }
.wcp-faq-item:last-child { border-bottom: 1px solid var(--wcp-rule-strong); }
.wcp-faq-btn { width: 100%; text-align: left; padding: 24px 0; background: transparent; border: 0; display: flex; justify-content: space-between; align-items: center; color: var(--wcp-ink); }
.wcp-faq-q { font-family: 'EB Garamond', serif; font-size: 22px; font-weight: 500; }
.wcp-faq-icon { font-size: 22px; font-family: 'EB Garamond', serif; transition: transform 0.3s ease; color: var(--wcp-accent); flex-shrink: 0; }
.wcp-faq-item.open .wcp-faq-icon { transform: rotate(45deg); }
.wcp-faq-body { max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.4s ease, opacity 0.3s ease, padding-bottom 0.3s ease; }
.wcp-faq-item.open .wcp-faq-body { max-height: 300px; opacity: 1; padding-bottom: 24px; }
.wcp-faq-body p { color: var(--wcp-ink-soft); font-size: 14px; line-height: 1.7; max-width: 560px; }

/* TESTIMONIALS */
.wcp-testimonials { padding: 100px 0; background: var(--wcp-bg-alt); border-top: 1px solid var(--wcp-rule); }
.wcp-testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.wcp-quote { margin: 0; padding: 36px 32px 32px; border: 1px solid var(--wcp-rule); background: var(--wcp-paper); display: flex; flex-direction: column; min-height: 320px; }
.wcp-quote-mark { font-family: 'EB Garamond', serif; font-style: italic; font-size: 72px; line-height: 0.7; color: var(--wcp-accent); margin-bottom: 12px; }
.wcp-quote blockquote { margin: 0; font-family: 'EB Garamond', serif; font-size: 20px; line-height: 1.35; color: var(--wcp-ink); flex: 1; }
.wcp-quote figcaption { margin-top: 28px; padding-top: 18px; border-top: 1px solid var(--wcp-rule); display: flex; justify-content: space-between; align-items: center; font-size: 13px; }
.wcp-tier-tag { padding: 4px 10px; border: 1px solid var(--wcp-rule-strong); color: var(--wcp-ink-mute); font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; }

/* CLOSING */
.wcp-closing { padding: 120px 0; background: var(--wcp-hero-bg); color: var(--wcp-hero-ink); text-align: center; }
.wcp-closing h2 { color: var(--wcp-hero-ink); font-size: clamp(40px, 5.5vw, 88px); max-width: 16ch; margin: 0 auto 40px; letter-spacing: -0.02em; }

/* STICKY */
.wcp-sticky { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(120px); opacity: 0; transition: transform 0.5s cubic-bezier(.65,.02,.3,1), opacity 0.3s ease; z-index: 200; pointer-events: none; background: var(--wcp-ink); color: var(--wcp-bg); border-radius: 100px; padding: 10px 10px 10px 28px; display: flex; align-items: center; gap: 20px; box-shadow: 0 12px 40px rgba(0,0,0,0.25); min-width: 460px; }
.wcp-sticky.visible { transform: translateX(-50%) translateY(0); opacity: 1; pointer-events: auto; }
.wcp-sticky-price { font-family: 'EB Garamond', serif; font-size: 20px; font-style: italic; }
.wcp-sticky-from { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,239,227,0.5); }

/* RESPONSIVE */
@media (max-width: 900px) {
  .wcp-container { padding: 0 20px; }
  .wcp-hero { padding: 60px 0 80px; }
  .wcp-hero-grid, .wcp-features-grid, .wcp-inbox-grid { grid-template-columns: 1fr; gap: 48px; }
  .wcp-hero h1 { font-size: 56px; }
  .wcp-how-grid { grid-template-columns: 1fr 1fr !important; }
  .wcp-journey-grid { grid-template-columns: repeat(6, 240px) !important; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 12px; }
  .wcp-journey-grid > div { scroll-snap-align: start; }
  .wcp-inbox-sticky { position: static; }
  .wcp-inbox-item { grid-template-columns: 1fr; gap: 8px; }
  .wcp-faq-grid { grid-template-columns: 1fr; gap: 32px; }
  .wcp-faq-sticky, .wcp-inbox-sticky { position: static; }
  .wcp-testimonials-grid { grid-template-columns: 1fr; }
  .wcp h2 { font-size: 36px !important; }
  .wcp-sticky { min-width: 0; width: calc(100vw - 24px); left: 12px; transform: translateY(120px); }
  .wcp-sticky.visible { transform: translateY(0); opacity: 1; }
}
</style>

<div class="wcp" id="wcp-root">

  {%- comment -%} HERO {%- endcomment -%}
  <section class="wcp-hero">
    <div class="wcp-container">
      <div class="wcp-hero-grid">
        <div>
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:28px;">
            <span style="width:32px;height:1px;background:var(--wcp-gold);display:block;"></span>
            <span class="wcp-mono" style="color:var(--wcp-gold);">El Cartel / The Whisky Club</span>
          </div>
          <span class="wcp-hero-subtitle">{{ section.settings.hero_subtitle }}</span>
          <h1>{{ tier_name }}</h1>
          <div style="display:inline-flex;align-items:center;gap:12px;margin:16px 0 0;padding:10px 20px;border:1px solid rgba(196,154,77,0.4);border-radius:100px;background:rgba(196,154,77,0.08);">
            <span style="font-family:'EB Garamond',serif;font-size:20px;font-style:italic;color:var(--wcp-gold);">6 &times; 25ml</span>
            <span style="width:1px;height:16px;background:rgba(196,154,77,0.3);display:block;"></span>
            <span class="wcp-mono" style="color:rgba(245,239,227,0.65);font-size:10px;">3 different whiskies</span>
          </div>
          <p style="font-size:16px;line-height:1.65;color:var(--wcp-hero-ink);opacity:0.78;max-width:480px;margin-top:20px;">
            {{ section.settings.hero_description }}
          </p>

          <div class="wcp-billing-wrap">
            <div class="wcp-billing-label">Choose your billing</div>
            <div class="wcp-billing-toggle" role="group">
              <div class="wcp-billing-track" id="wcp-billing-track"></div>
              <button class="wcp-billing-btn active" data-billing="monthly">Monthly</button>
              <button class="wcp-billing-btn" data-billing="annual">Annual&nbsp;<span style="opacity:0.7;">&middot;&nbsp;save&nbsp;15%</span></button>
            </div>
            <div class="wcp-price-row">
              <span class="wcp-price-currency">&euro;</span>
              <span class="wcp-price-amount" id="wcp-price">{{ price_monthly }}</span>
              <span class="wcp-price-period">/ month</span>
            </div>
            <div class="wcp-price-note" id="wcp-price-note">Billed monthly &middot; cancel any time</div>
          </div>

          {%- if product != blank -%}
            <form action="/cart/add" method="post" id="wcp-product-form">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              {%- if product.selling_plan_groups.size > 0 -%}
                {%- for group in product.selling_plan_groups -%}
                  {%- for plan in group.selling_plans -%}
                    {%- if plan.name contains 'month' or plan.name contains 'Month' -%}
                      <input type="hidden" id="wcp-plan-monthly" data-plan-id="{{ plan.id }}">
                    {%- elsif plan.name contains 'year' or plan.name contains 'Year' or plan.name contains 'annual' or plan.name contains 'Annual' -%}
                      <input type="hidden" id="wcp-plan-annual" data-plan-id="{{ plan.id }}">
                    {%- endif -%}
                  {%- endfor -%}
                {%- endfor -%}
                <input type="hidden" name="selling_plan" id="wcp-selling-plan-input" value="">
              {%- endif -%}
              <button type="submit" class="wcp-subscribe-btn">
                <span>Subscribe to {{ tier_name }}</span><span>&rarr;</span>
              </button>
            </form>
          {%- else -%}
            <a id="wcp-subscribe-link" href="{{ section.settings.monthly_url | default: '#' }}" class="wcp-subscribe-btn">
              <span>Subscribe to {{ tier_name }}</span><span>&rarr;</span>
            </a>
          {%- endif -%}

          <div class="wcp-trust">
            <span class="wcp-trust-item">&#10003;&nbsp;Free Belgium shipping</span>
            <span class="wcp-trust-item">&#10003;&nbsp;Pause, skip or cancel</span>
            <span class="wcp-trust-item">&#10003;&nbsp;30-day guarantee</span>
          </div>
        </div>

        <div>
          <div class="wcp-hero-media">
            {%- if section.settings.hero_image != blank -%}
              {{ section.settings.hero_image | image_url: width: 900 | image_tag: loading: 'eager' }}
            {%- else -%}
              {{ tier_name }} — product photography
            {%- endif -%}
            <div class="wcp-tier-badge">
              <div class="wcp-tier-badge-initial">{{ tier_initial }}</div>
              <div>
                <div style="font-family:'EB Garamond',serif;font-size:22px;font-style:italic;color:var(--wcp-hero-ink);">{{ tier_name }}</div>
                <div class="wcp-mono" style="color:var(--wcp-gold);margin-top:2px;">Whisky Club</div>
              </div>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,0.1);margin-top:1px;">
            <div style="background:var(--wcp-hero-bg);padding:20px 24px;">
              <div style="font-family:'EB Garamond',serif;font-size:24px;color:var(--wcp-hero-ink);">{{ section.settings.stat_1_value }}</div>
              <div class="wcp-mono" style="color:rgba(245,239,227,0.45);margin-top:4px;font-size:10px;">{{ section.settings.stat_1_label }}</div>
            </div>
            <div style="background:var(--wcp-hero-bg);padding:20px 24px;">
              <div style="font-family:'EB Garamond',serif;font-size:24px;color:var(--wcp-hero-ink);">{{ section.settings.stat_2_value }}</div>
              <div class="wcp-mono" style="color:rgba(245,239,227,0.45);margin-top:4px;font-size:10px;">{{ section.settings.stat_2_label }}</div>
            </div>
            <div style="background:var(--wcp-hero-bg);padding:20px 24px;">
