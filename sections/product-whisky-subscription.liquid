{% comment %}
  Whisky Subscription — Product Page (Explorer or Advanced)
  Design-faithful rebuild of the Claude Design prototype, split per tier.
  All text editable via theme editor. Blocks: feature, how_step,
  journey_box, box_item, compare_row, testimonial, faq.
{% endcomment %}

{%- assign tier = section.settings.tier | default: 'explorer' -%}
{%- assign is_explorer = false -%}
{%- if tier == 'explorer' -%}{%- assign is_explorer = true -%}{%- endif -%}

{%- if is_explorer -%}
  {%- assign tier_name     = 'Explorer' -%}
  {%- assign tier_initial  = 'E' -%}
  {%- assign price_monthly = 40 -%}
  {%- assign price_annual  = 34 -%}
  {%- assign annual_total  = 408 -%}
  {%- assign other_tier    = 'Advanced' -%}
  {%- assign other_price   = 42 -%}
{%- else -%}
  {%- assign tier_name     = 'Advanced' -%}
  {%- assign tier_initial  = 'A' -%}
  {%- assign price_monthly = 50 -%}
  {%- assign price_annual  = 42 -%}
  {%- assign annual_total  = 504 -%}
  {%- assign other_tier    = 'Explorer' -%}
  {%- assign other_price   = 34 -%}
{%- endif -%}

{%- assign feature_blocks     = section.blocks | where: "type", "feature" -%}
{%- assign how_blocks         = section.blocks | where: "type", "how_step" -%}
{%- assign journey_blocks     = section.blocks | where: "type", "journey_box" -%}
{%- assign box_blocks         = section.blocks | where: "type", "box_item" -%}
{%- assign compare_blocks     = section.blocks | where: "type", "compare_row" -%}
{%- assign testimonial_blocks = section.blocks | where: "type", "testimonial" -%}
{%- assign faq_blocks         = section.blocks | where: "type", "faq" -%}

{%- assign other_tier_url = section.settings.other_tier_url | default: '/pages/whisky-club' -%}
{%- assign club_page_url  = section.settings.club_page_url  | default: '/pages/whisky-club' -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Montserrat:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
/* ==========================================================
   Whisky Subscription — product page (scoped to .wcp)
   ========================================================== */
.wcp {
  --wcp-bg:          #f5efe3;
  --wcp-bg-alt:      #ebe2cf;
  --wcp-surface:     #fcf9f2;
  --wcp-ink:         #1a1814;
  --wcp-ink-soft:    #4a4538;
  --wcp-ink-mute:    #7a7362;
  --wcp-rule:        rgba(26,24,20,0.14);
  --wcp-rule-strong: rgba(26,24,20,0.35);
  --wcp-accent:      #2d4f8a;
  --wcp-accent-ink:  #fcf9f2;
  --wcp-paper:       #fcf9f2;
  --wcp-hero-bg:     #1f1c17;
  --wcp-hero-ink:    #f5efe3;
  --wcp-hero-accent: #c49a4d;
  --wcp-ph-a:        rgba(26,24,20,0.05);
  --wcp-ph-b:        rgba(26,24,20,0.12);

  font-family: 'Montserrat', system-ui, sans-serif;
  font-weight: 400;
  background: var(--wcp-bg);
  color: var(--wcp-ink);
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
}
.wcp *, .wcp *::before, .wcp *::after { box-sizing: border-box; }
.wcp h1, .wcp h2, .wcp h3, .wcp h4 {
  font-family: 'EB Garamond', Georgia, serif;
  font-weight: 500; letter-spacing: -0.01em; line-height: 1.08; margin: 0;
  color: var(--wcp-ink);
}
.wcp p { margin: 0; }
.wcp button { font-family: inherit; cursor: pointer; }
.wcp a { cursor: pointer; }
.wcp-mono { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; }
.wcp-eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--wcp-ink-mute); }
.wcp-container { max-width: 1320px; margin: 0 auto; padding: 0 40px; }

/* ---------- HERO ---------- */
.wcp-hero { background: var(--wcp-hero-bg); color: var(--wcp-hero-ink); padding: 120px 0 100px; position: relative; overflow: hidden; }
.wcp-hero-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 80px; align-items: center; }
.wcp-hero-eyebrow-row { display: flex; align-items: center; gap: 12px; margin-bottom: 32px; }
.wcp-hero-eyebrow-rule { width: 40px; height: 1px; background: var(--wcp-hero-accent); display: block; }
.wcp-hero-eyebrow-text { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--wcp-hero-accent); }
.wcp-hero h1 { color: var(--wcp-hero-ink); font-size: clamp(44px, 5.6vw, 88px); letter-spacing: -0.02em; max-width: 16ch; margin-bottom: 32px; }
.wcp-hero h1 em { font-style: italic; font-weight: 400; }
.wcp-hero-lead { font-size: 17px; line-height: 1.6; max-width: 520px; color: var(--wcp-hero-ink); opacity: 0.78; margin-bottom: 0; }
.wcp-hero-cta-row { display: flex; gap: 20px; align-items: center; flex-wrap: wrap; margin-top: 36px; }
.wcp-btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: var(--wcp-hero-accent); color: #1a1814; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; border-radius: 100px; text-decoration: none; font-weight: 500; border: 0; transition: opacity 0.2s ease; cursor: pointer; }
.wcp-btn-primary:hover { opacity: 0.92; }
.wcp-btn-ghost { color: var(--wcp-hero-ink); text-decoration: underline; text-decoration-color: var(--wcp-hero-accent); text-underline-offset: 6px; font-size: 13px; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.1em; text-transform: uppercase; }
.wcp-hero-media { position: relative; height: 560px; }
.wcp-hero-media-inner { position: absolute; inset: 0; border: 1px solid rgba(255,255,255,0.1); background: repeating-linear-gradient(135deg, rgba(255,255,255,0.02) 0 10px, rgba(255,255,255,0.05) 10px 20px); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.4); font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; overflow: hidden; }
.wcp-hero-media-inner img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.wcp-hero-stamp { position: absolute; top: -20px; right: -20px; width: 140px; height: 140px; border-radius: 50%; border: 1px solid var(--wcp-hero-accent); display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--wcp-hero-accent); font-family: 'EB Garamond', serif; font-style: italic; font-size: 18px; transform: rotate(-12deg); background: var(--wcp-hero-bg); text-align: center; line-height: 1.1; }
.wcp-hero-stamp-big { font-size: 32px; font-weight: 500; display: block; }
.wcp-hero-stamp-sub { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; font-family: 'JetBrains Mono', monospace; font-style: normal; display: block; margin-top: 4px; }
.wcp-hero-stats { margin-top: 100px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.1); display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; }
.wcp-hero-stat-n { font-family: 'EB Garamond', serif; font-size: 36px; letter-spacing: -0.01em; color: var(--wcp-hero-ink); }
.wcp-hero-stat-l { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-top: 8px; }

/* ---------- PLAN / MEMBERSHIP SECTION ---------- */
.wcp-plan-section { padding: 140px 0 80px; background: var(--wcp-bg); }
.wcp-plan-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 60px; gap: 40px; flex-wrap: wrap; }
.wcp-plan-head h2 { font-size: clamp(40px, 4.5vw, 68px); max-width: 14ch; }
.wcp-plan-head h2 em { font-style: italic; font-weight: 400; }
.wcp-billing-toggle { display: inline-flex; padding: 5px; border-radius: 100px; background: var(--wcp-surface); border: 1px solid var(--wcp-rule); position: relative; box-shadow: inset 0 1px 3px rgba(26,24,20,0.08); }
.wcp-billing-track { position: absolute; top: 5px; bottom: 5px; left: 5px; width: calc(50% - 7px); background: var(--wcp-ink); border-radius: 100px; transition: left 0.35s cubic-bezier(.65,.02,.3,1); box-shadow: 0 2px 8px rgba(26,24,20,0.18); }
.wcp-billing-btn { position: relative; background: transparent; border: 0; padding: 12px 32px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--wcp-ink-mute); transition: color 0.3s ease; font-weight: 500; white-space: nowrap; }
.wcp-billing-btn.active { color: var(--wcp-surface); }
.wcp-plan-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 32px; align-items: start; }
.wcp-plan { border: 1px solid var(--wcp-rule); padding: 48px 40px; display: flex; flex-direction: column; position: relative; min-height: 620px; background: var(--wcp-paper); color: var(--wcp-ink); }
.wcp-plan--featured { background: var(--wcp-ink); color: var(--wcp-bg); border-color: var(--wcp-ink); }
.wcp-plan-badge { position: absolute; top: -12px; left: 40px; background: var(--wcp-accent); color: var(--wcp-accent-ink); padding: 6px 14px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; }
.wcp-plan-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
.wcp-plan-sub { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--wcp-ink-mute); }
.wcp-plan--featured .wcp-plan-sub { color: rgba(245,239,227,0.55); }
.wcp-plan-name { margin-top: 8px; font-family: 'EB Garamond', serif; font-size: 48px; font-style: italic; font-weight: 400; letter-spacing: -0.01em; line-height: 1; }
.wcp-plan--featured .wcp-plan-name { color: var(--wcp-bg); }
.wcp-plan-initial { width: 48px; height: 48px; border-radius: 50%; border: 1px solid var(--wcp-rule-strong); display: flex; align-items: center; justify-content: center; font-family: 'EB Garamond', serif; font-style: italic; font-size: 20px; flex-shrink: 0; }
.wcp-plan--featured .wcp-plan-initial { border-color: rgba(245,239,227,0.3); color: var(--wcp-bg); }
.wcp-plan-desc { font-size: 14px; line-height: 1.6; color: var(--wcp-ink-soft); margin-bottom: 32px; }
.wcp-plan--featured .wcp-plan-desc { color: rgba(245,239,227,0.75); }
.wcp-price-block { padding: 24px 0; border-top: 1px solid var(--wcp-rule); border-bottom: 1px solid var(--wcp-rule); margin-bottom: 32px; }
.wcp-plan--featured .wcp-price-block { border-color: rgba(245,239,227,0.15); }
.wcp-price-row { display: flex; align-items: baseline; gap: 8px; }
.wcp-price-currency { font-family: 'EB Garamond', serif; font-size: 28px; line-height: 1; }
.wcp-price-amount { font-family: 'EB Garamond', serif; font-size: 72px; line-height: 1; letter-spacing: -0.02em; font-weight: 500; transition: opacity 0.22s cubic-bezier(.65,.02,.3,1), transform 0.22s cubic-bezier(.65,.02,.3,1); font-variant-numeric: tabular-nums; display: inline-block; }
.wcp-price-unit { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--wcp-ink-mute); margin-left: 6px; }
.wcp-plan--featured .wcp-price-unit { color: rgba(245,239,227,0.6); }
.wcp-price-note { margin-top: 8px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--wcp-ink-mute); }
.wcp-plan--featured .wcp-price-note { color: rgba(245,239,227,0.55); }
.wcp-plan-features { list-style: none; padding: 0; margin: 0 0 40px; display: flex; flex-direction: column; gap: 14px; }
.wcp-plan-features li { display: flex; gap: 14px; align-items: flex-start; font-size: 14px; color: var(--wcp-ink-soft); }
.wcp-plan--featured .wcp-plan-features li { color: rgba(245,239,227,0.9); }
.wcp-plan-features li::before { content: ''; margin-top: 6px; width: 6px; height: 6px; border-radius: 50%; background: var(--wcp-accent); flex-shrink: 0; }
.wcp-plan--featured .wcp-plan-features li::before { background: var(--wcp-hero-accent); }
.wcp-plan-cta { margin-top: auto; background: var(--wcp-ink); color: var(--wcp-bg); border: 0; padding: 20px 32px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; border-radius: 100px; font-weight: 500; display: flex; align-items: center; justify-content: space-between; text-decoration: none; cursor: pointer; width: 100%; }
.wcp-plan--featured .wcp-plan-cta { background: var(--wcp-hero-accent); color: #1a1814; }
.wcp-plan-side { background: var(--wcp-paper); border: 1px solid var(--wcp-rule); padding: 36px 32px; display: flex; flex-direction: column; align-self: stretch; }
.wcp-plan-side-title { font-family: 'EB Garamond', serif; font-size: 28px; font-style: italic; font-weight: 400; margin-bottom: 12px; }
.wcp-plan-side-body { font-size: 14px; color: var(--wcp-ink-soft); line-height: 1.6; margin-bottom: 24px; }
.wcp-plan-side-price { font-family: 'EB Garamond', serif; font-size: 44px; line-height: 1; letter-spacing: -0.02em; margin-bottom: 24px; }
.wcp-plan-side-price small { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--wcp-ink-mute); margin-left: 6px; font-weight: 400; }
.wcp-plan-side-link { margin-top: auto; padding: 18px 28px; border: 1px solid var(--wcp-ink); color: var(--wcp-ink); text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; text-align: center; font-weight: 500; transition: background 0.2s ease, color 0.2s ease; }
.wcp-plan-side-link:hover { background: var(--wcp-ink); color: var(--wcp-bg); }
.wcp-guarantee { margin-top: 32px; padding: 20px 32px; background: var(--wcp-bg-alt); border-left: 2px solid var(--wcp-accent); display: flex; gap: 24px; align-items: center; flex-wrap: wrap; justify-content: space-between; }
.wcp-guarantee-text { font-size: 13px; color: var(--wcp-ink-soft); max-width: 720px; }
.wcp-guarantee-text strong { color: var(--wcp-ink); }

/* ---------- HOW IT WORKS ---------- */
.wcp-how { padding: 120px 0; background: var(--wcp-bg-alt); border-top: 1px solid var(--wcp-rule); border-bottom: 1px solid var(--wcp-rule); }
.wcp-how-head { max-width: 720px; margin-bottom: 80px; }
.wcp-how-head h2 { font-size: clamp(40px, 4.5vw, 68px); }
.wcp-how-head h2 em { font-style: italic; font-weight: 400; }
.wcp-how-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--wcp-rule-strong); }
.wcp-how-step { background: var(--wcp-bg-alt); padding: 40px 32px 48px; display: flex; flex-direction: column; min-height: 320px; }
.wcp-step-n { font-family: 'EB Garamond', serif; font-style: italic; font-size: 56px; color: var(--wcp-accent); line-height: 1; margin-bottom: 24px; }
.wcp-step-t { font-size: 26px; margin-bottom: 16px; letter-spacing: -0.01em; }
.wcp-step-d { font-size: 13.5px; color: var(--wcp-ink-soft); line-height: 1.6; margin-top: auto; }

/* ---------- JOURNEY ---------- */
.wcp-journey { padding: 140px 0; background: var(--wcp-bg); }
.wcp-journey-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 60px; gap: 40px; flex-wrap: wrap; }
.wcp-journey-head h2 { font-size: clamp(40px, 4.5vw, 68px); padding-bottom: 0.15em; max-width: 18ch; }
.wcp-journey-head h2 em { font-style: italic; font-weight: 400; }
.wcp-journey-head p { font-size: 16px; color: var(--wcp-ink-soft); line-height: 1.65; margin-top: 28px; max-width: 560px; }
.wcp-journey-timeline { position: relative; }
.wcp-journey-line { position: absolute; top: 48px; left: 0; right: 0; height: 1px; background: var(--wcp-rule-strong); }
.wcp-curriculum-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 20px; }
.wcp-jbox { display: flex; flex-direction: column; gap: 20px; position: relative; }
.wcp-jdot-row { height: 96px; display: flex; align-items: center; justify-content: flex-start; position: relative; }
.wcp-jdot { width: 16px; height: 16px; border-radius: 50%; background: var(--wcp-bg); border: 2px solid var(--wcp-rule-strong); margin-left: 32px; }
.wcp-jdot--active { background: var(--wcp-accent); border-color: var(--wcp-accent); }
.wcp-jstart { position: absolute; top: -24px; left: 24px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--wcp-accent); white-space: nowrap; }
.wcp-jcard { border: 1px solid var(--wcp-rule); padding: 24px 22px 28px; background: var(--wcp-paper); min-height: 240px; display: flex; flex-direction: column; position: relative; overflow: hidden; }
.wcp-jcard--locked { background: transparent; }
.wcp-jcard--locked::after { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(135deg, var(--wcp-ph-a) 0 8px, var(--wcp-ph-b) 8px 16px); opacity: 0.5; }
.wcp-jcard__inner { position: relative; display: flex; flex-direction: column; height: 100%; }
.wcp-jcard-top { display: flex; justify-content: space-between; margin-bottom: 16px; align-items: baseline; }
.wcp-jbox-n { font-family: 'EB Garamond', serif; font-style: italic; font-size: 40px; line-height: 1; color: var(--wcp-accent); }
.wcp-jbox-n--locked { color: var(--wcp-ink-mute); }
.wcp-jbox-mo { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--wcp-ink-mute); }
.wcp-jbox-title { font-size: 20px; margin-bottom: 10px; letter-spacing: -0.01em; }
.wcp-jbox-title--locked { color: var(--wcp-ink-mute); font-style: italic; }
.wcp-jbox-hint { font-size: 12.5px; color: var(--wcp-ink-soft); line-height: 1.55; margin: 0; font-style: italic; }
.wcp-jbox-revealed { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; margin-top: auto; padding-top: 16px; color: var(--wcp-ink-mute); }
.wcp-journey-foot { margin-top: 40px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: var(--wcp-ink-soft); gap: 24px; flex-wrap: wrap; }
.wcp-journey-foot strong { color: var(--wcp-ink); }

/* ---------- IN THE BOX ---------- */
.wcp-inbox { padding: 140px 0; background: var(--wcp-bg); }
.wcp-inbox-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 100px; align-items: start; }
.wcp-inbox-sticky { position: sticky; top: 100px; }
.wcp-inbox-sticky h2 { font-size: clamp(40px, 4.5vw, 68px); margin-bottom: 32px; }
.wcp-inbox-sticky h2 em { font-style: italic; font-weight: 400; }
.wcp-inbox-sticky p { font-size: 16px; color: var(--wcp-ink-soft); line-height: 1.7; max-width: 420px; margin-bottom: 40px; }
.wcp-inbox-image { aspect-ratio: 1/1; width: 100%; max-width: 420px; position: relative; overflow: hidden; }
.wcp-inbox-image img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.wcp-inbox-image-ph { aspect-ratio: 1/1; width: 100%; max-width: 420px; background: repeating-linear-gradient(135deg, var(--wcp-ph-a) 0 10px, var(--wcp-ph-b) 10px 20px); display: flex; align-items: center; justify-content: center; color: var(--wcp-ink-mute); font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; text-align: center; padding: 1.5rem; }
.wcp-inbox-item { padding: 36px 0; border-top: 1px solid var(--wcp-rule); display: grid; grid-template-columns: 100px 1fr; gap: 32px; }
.wcp-inbox-item:first-child { border-top-color: var(--wcp-ink); }
.wcp-inbox-item:last-child { border-bottom: 1px solid var(--wcp-ink); }
.wcp-inbox-item-n { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--wcp-ink-mute); margin-bottom: 8px; }
.wcp-inbox-item-tag { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--wcp-accent); }
.wcp-inbox-item h3 { font-size: 32px; margin-bottom: 12px; font-style: italic; font-weight: 400; }
.wcp-inbox-item p { font-size: 15px; color: var(--wcp-ink-soft); line-height: 1.65; }

/* ---------- COMPARE TABLE ---------- */
.wcp-compare { padding: 120px 0; background: var(--wcp-bg-alt); border-top: 1px solid var(--wcp-rule); border-bottom: 1px solid var(--wcp-rule); }
.wcp-compare-head { margin-bottom: 60px; max-width: 680px; }
.wcp-compare-head h2 { font-size: clamp(40px, 4.5vw, 68px); }
.wcp-compare-head h2 em { font-style: italic; font-weight: 400; }
.wcp-compare-table { border: 1px solid var(--wcp-rule-strong); background: var(--wcp-paper); }
.wcp-compare-th { display: grid; grid-template-columns: 1.4fr 1fr 1fr; border-bottom: 1px solid var(--wcp-rule-strong); background: var(--wcp-ink); color: var(--wcp-bg); }
.wcp-compare-th-cell { padding: 24px 32px; }
.wcp-compare-th-cell-border { border-left: 1px solid rgba(255,255,255,0.15); }
.wcp-compare-th-cell-adv { border-left: 1px solid rgba(255,255,255,0.15); background: rgba(196,154,77,0.12); }
.wcp-compare-th-label { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,239,227,0.55); margin-bottom: 4px; }
.wcp-compare-th-label--adv { color: var(--wcp-hero-accent); }
.wcp-compare-th-name { font-family: 'EB Garamond', serif; font-size: 24px; font-style: italic; }
.wcp-compare-row { display: grid; grid-template-columns: 1.4fr 1fr 1fr; border-bottom: 1px solid var(--wcp-rule); font-size: 14px; }
.wcp-compare-row:last-child { border-bottom: 0; }
.wcp-compare-cell { padding: 20px 32px; }
.wcp-compare-cell-feat { color: var(--wcp-ink-soft); font-weight: 500; }
.wcp-compare-cell-exp { border-left: 1px solid var(--wcp-rule); }
.wcp-compare-cell-adv { border-left: 1px solid var(--wcp-rule); background: rgba(196,154,77,0.05); }
.wcp-dot { font-family: 'EB Garamond', serif; font-size: 22px; color: var(--wcp-ink); }
.wcp-dash { font-family: 'EB Garamond', serif; font-size: 22px; color: var(--wcp-ink-mute); }

/* ---------- TESTIMONIALS ---------- */
.wcp-testimonials { padding: 140px 0; background: var(--wcp-bg); }
.wcp-testimonials-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 80px; gap: 40px; flex-wrap: wrap; }
.wcp-testimonials-head h2 { font-size: clamp(40px, 4.5vw, 68px); max-width: 16ch; }
.wcp-testimonials-head h2 em { font-style: italic; font-weight: 400; }
.wcp-rating-badge { padding: 16px 24px; border: 1px solid var(--wcp-rule-strong); font-family: 'EB Garamond', serif; display: flex; align-items: center; gap: 16px; }
.wcp-rating-n { font-size: 36px; font-style: italic; line-height: 1; }
.wcp-rating-stars { letter-spacing: 2px; font-size: 14px; }
.wcp-testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.wcp-quote { margin: 0; padding: 40px 36px 36px; border: 1px solid var(--wcp-rule); background: var(--wcp-paper); display: flex; flex-direction: column; min-height: 340px; }
.wcp-quote-mark { font-family: 'EB Garamond', serif; font-style: italic; font-size: 80px; line-height: 0.7; color: var(--wcp-accent); margin-bottom: 12px; }
.wcp-quote blockquote { margin: 0; font-family: 'EB Garamond', serif; font-size: 22px; line-height: 1.35; color: var(--wcp-ink); flex: 1; }
.wcp-quote figcaption { margin-top: 32px; padding-top: 20px; border-top: 1px solid var(--wcp-rule); display: flex; justify-content: space-between; align-items: center; font-size: 13px; }
.wcp-quote-author { font-weight: 600; }
.wcp-quote-meta { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--wcp-ink-mute); margin-top: 4px; }
.wcp-tier-tag { padding: 4px 10px; border: 1px solid var(--wcp-rule-strong); color: var(--wcp-ink-soft); font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; }

/* ---------- FAQ ---------- */
.wcp-faq { padding: 120px 0; background: var(--wcp-bg-alt); border-top: 1px solid var(--wcp-rule); }
.wcp-faq-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 80px; align-items: start; }
.wcp-faq-sticky { position: sticky; top: 100px; }
.wcp-faq-sticky h2 { font-size: clamp(36px, 4vw, 56px); margin-bottom: 24px; }
.wcp-faq-sticky h2 em { font-style: italic; font-weight: 400; }
.wcp-faq-sticky p { font-size: 15px; color: var(--wcp-ink-soft); line-height: 1.65; }
.wcp-faq-item { border-top: 1px solid var(--wcp-rule-strong); }
.wcp-faq-item:last-child { border-bottom: 1px solid var(--wcp-rule-strong); }
.wcp-faq-btn { width: 100%; text-align: left; padding: 28px 0; background: transparent; border: 0; display: flex; justify-content: space-between; align-items: center; color: var(--wcp-ink); gap: 24px; }
.wcp-faq-q { font-family: 'EB Garamond', serif; font-size: 24px; font-weight: 500; }
.wcp-faq-icon { font-size: 24px; font-family: 'EB Garamond', serif; transition: transform 0.3s ease; color: var(--wcp-accent); flex-shrink: 0; }
.wcp-faq-item.open .wcp-faq-icon { transform: rotate(45deg); }
.wcp-faq-body { max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.4s ease, opacity 0.3s ease, padding-bottom 0.3s ease; }
.wcp-faq-item.open .wcp-faq-body { max-height: 300px; opacity: 1; padding-bottom: 28px; }
.wcp-faq-body p { margin: 0; color: var(--wcp-ink-soft); font-size: 15px; line-height: 1.7; max-width: 640px; }

/* ---------- CLOSING ---------- */
.wcp-closing { padding: 140px 0; background: var(--wcp-hero-bg); color: var(--wcp-hero-ink); text-align: center; position: relative; overflow: hidden; }
.wcp-closing-eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--wcp-hero-accent); margin-bottom: 32px; }
.wcp-closing h2 { color: var(--wcp-hero-ink); font-size: clamp(48px, 6.5vw, 104px); max-width: 14ch; margin: 0 auto 40px; letter-spacing: -0.02em; }
.wcp-closing h2 em { color: var(--wcp-hero-accent); font-style: italic; font-weight: 400; }
.wcp-closing p { max-width: 540px; margin: 0 auto 48px; font-size: 17px; line-height: 1.6; color: rgba(245,239,227,0.75); }

/* ---------- STICKY CTA ---------- */
.wcp-sticky { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(120px); opacity: 0; transition: transform 0.5s cubic-bezier(.65,.02,.3,1), opacity 0.3s ease; z-index: 20; background: var(--wcp-ink); color: var(--wcp-bg); border-radius: 100px; padding: 10px 10px 10px 28px; display: flex; align-items: center; gap: 24px; box-shadow: 0 12px 40px rgba(0,0,0,0.25); min-width: 520px; pointer-events: none; }
.wcp-sticky.visible { transform: translateX(-50%) translateY(0); opacity: 1; pointer-events: auto; }
.wcp-sticky-label { display: flex; flex-direction: column; }
.wcp-sticky-from { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,239,227,0.55); }
.wcp-sticky-title { font-family: 'EB Garamond', serif; font-size: 20px; font-style: italic; }
.wcp-sticky-toggle { display: flex; padding: 3px; border-radius: 100px; background: rgba(255,255,255,0.1); position: relative; }
.wcp-sticky-track { position: absolute; top: 3px; bottom: 3px; left: 3px; width: calc(50% - 4px); background: var(--wcp-bg); border-radius: 100px; transition: left 0.3s cubic-bezier(.65,.02,.3,1); }
.wcp-sticky-btn { position: relative; background: transparent; border: 0; padding: 8px 16px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,239,227,0.7); transition: color 0.3s ease; }
.wcp-sticky-btn.active { color: var(--wcp-ink); }
.wcp-sticky-cta { background: var(--wcp-hero-accent); color: #1a1814; border-radius: 100px; padding: 14px 24px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 8px; border: 0; cursor: pointer; }

/* ---------- RESPONSIVE ---------- */
@media (max-width: 960px) {
  .wcp-container { padding: 0 20px; }
  .wcp-hero { padding: 72px 0 64px; }
  .wcp-hero-grid { grid-template-columns: 1fr; gap: 48px; }
  .wcp-hero h1 { font-size: 44px; }
  .wcp-hero-media { height: 360px; }
  .wcp-hero-stamp { width: 100px; height: 100px; top: -10px; right: -10px; font-size: 12px; }
  .wcp-hero-stamp-big { font-size: 24px; }
  .wcp-hero-stats { grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 56px; }
  .wcp-plan-section, .wcp-how, .wcp-journey, .wcp-inbox, .wcp-compare, .wcp-testimonials, .wcp-faq, .wcp-closing { padding-top: 72px !important; padding-bottom: 72px !important; }
  .wcp-plan-grid { grid-template-columns: 1fr; gap: 16px; }
  .wcp-how-grid { grid-template-columns: 1fr 1fr; }
  .wcp-curriculum-grid { grid-template-columns: repeat(6, 260px); overflow-x: auto; padding-bottom: 12px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
  .wcp-curriculum-grid > div { scroll-snap-align: start; }
  .wcp-inbox-grid { grid-template-columns: 1fr; gap: 40px; }
  .wcp-inbox-sticky { position: static; }
  .wcp-inbox-item { grid-template-columns: 1fr; gap: 12px; padding: 28px 0; }
  .wcp-compare-row { grid-template-columns: 1fr; }
  .wcp-compare-cell { border-left: 0 !important; padding: 14px 20px; }
  .wcp-compare-cell-feat { background: var(--wcp-bg-alt); font-weight: 600; color: var(--wcp-ink); border-bottom: 1px solid var(--wcp-rule); }
  .wcp-compare-th { grid-template-columns: 1fr 1fr; }
  .wcp-compare-th-cell:first-child { display: none; }
  .wcp-testimonials-grid { grid-template-columns: 1fr; }
  .wcp-quote { min-height: 260px; padding: 28px 24px; }
  .wcp-quote blockquote { font-size: 18px; }
  .wcp-faq-grid { grid-template-columns: 1fr; gap: 32px; }
  .wcp-faq-sticky { position: static; }
  .wcp-faq-q { font-size: 18px; }
  .wcp-closing h2 { font-size: 48px; }
  .wcp-sticky { min-width: 0; width: calc(100vw - 24px); left: 12px; transform: translateY(120px); padding: 8px 8px 8px 20px; gap: 12px; }
  .wcp-sticky.visible { transform: translateY(0); }
  .wcp-sticky-label, .wcp-sticky-toggle { display: none; }
}
</style>

<div class="wcp" id="wcp-root">

  {%- comment -%} ===== HERO ===== {%- endcomment -%}
  <section class="wcp-hero">
    <div class="wcp-container">
      <div class="wcp-hero-grid">
        <div>
          <div class="wcp-hero-eyebrow-row">
            <span class="wcp-hero-eyebrow-rule"></span>
            <span class="wcp-hero-eyebrow-text">{{ section.settings.hero_eyebrow }}</span>
          </div>
          <h1>{{ section.settings.hero_headline }}</h1>
          <p class="wcp-hero-lead">{{ section.settings.hero_description }}</p>
          <div class="wcp-hero-cta-row">
            <a href="#plans" class="wcp-btn-primary">{{ section.settings.hero_cta_label | default: 'See the plan' }} <span>&rarr;</span></a>
            <a href="#how" class="wcp-btn-ghost">How it works</a>
          </div>
        </div>
        <div class="wcp-hero-media">
          <div class="wcp-hero-media-inner">
            {%- if section.settings.hero_image != blank -%}
              {{ section.settings.hero_image | image_url: width: 1000 | image_tag: loading: 'eager', alt: tier_name }}
            {%- else -%}
              Hero product shot<br>&mdash; monthly box, opened
            {%- endif -%}
          </div>
          <div class="wcp-hero-stamp">
            <span>{{ section.settings.stamp_prefix | default: 'No.' }}</span>
            <span class="wcp-hero-stamp-big">{{ section.settings.stamp_number | default: '47' }}</span>
            <span class="wcp-hero-stamp-sub">{{ section.settings.stamp_date | default: 'Apr &middot; 26' }}</span>
          </div>
        </div>
      </div>

      <div class="wcp-hero-stats">
        <div>
          <div class="wcp-hero-stat-n">{{ section.settings.stat_1_value }}</div>
          <div class="wcp-hero-stat-l">{{ section.settings.stat_1_label }}</div>
        </div>
        <div>
          <div class="wcp-hero-stat-n">{{ section.settings.stat_2_value }}</div>
          <div class="wcp-hero-stat-l">{{ section.settings.stat_2_label }}</div>
        </div>
        <div>
          <div class="wcp-hero-stat-n">{{ section.settings.stat_3_value }}</div>
          <div class="wcp-hero-stat-l">{{ section.settings.stat_3_label }}</div>
        </div>
        <div>
          <div class="wcp-hero-stat-n">{{ section.settings.stat_4_value }}</div>
          <div class="wcp-hero-stat-l">{{ section.settings.stat_4_label }}</div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ===== MEMBERSHIP / PLAN ===== {%- endcomment -%}
  <section class="wcp-plan-section" id="plans">
    <div class="wcp-container">
      <div class="wcp-plan-head">
        <div>
          <div class="wcp-eyebrow" style="margin-bottom:16px;">&sect; 01 &mdash; Membership</div>
          <h2>{{ section.settings.plan_headline }}</h2>
        </div>
        <div class="wcp-billing-toggle" role="group">
          <div class="wcp-billing-track" id="wcp-billing-track"></div>
          <button class="wcp-billing-btn active" data-billing="monthly">Monthly</button>
          <button class="wcp-billing-btn" data-billing="annual">Annual&nbsp;<span style="margin-left:6px;opacity:0.8;">&middot;&nbsp;save&nbsp;15%</span></button>
        </div>
      </div>

      <div class="wcp-plan-grid">
        <div class="wcp-plan{% unless is_explorer %} wcp-plan--featured{% endunless %}">
          {%- unless is_explorer -%}
            <div class="wcp-plan-badge">Most Chosen</div>
          {%- endunless -%}
          <div class="wcp-plan-top">
            <div>
              <div class="wcp-plan-sub">{{ section.settings.plan_subtitle }}</div>
              <h3 class="wcp-plan-name">{{ tier_name }}</h3>
            </div>
            <div class="wcp-plan-initial">{{ tier_initial }}</div>
          </div>
          <p class="wcp-plan-desc">{{ section.settings.plan_description }}</p>

          <div class="wcp-price-block">
            <div class="wcp-price-row">
              <span class="wcp-price-currency">&euro;</span>
              <span class="wcp-price-amount" id="wcp-price">{{ price_monthly }}</span>
              <span class="wcp-price-unit">/ month</span>
            </div>
            <div class="wcp-price-note" id="wcp-price-note">Billed monthly &middot; cancel any time</div>
          </div>

          {%- if feature_blocks.size > 0 -%}
            <ul class="wcp-plan-features">
              {%- for block in feature_blocks -%}
                <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          {%- if product != blank -%}
            <form action="/cart/add" method="post" id="wcp-product-form" style="margin-top:auto;">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              {%- if product.selling_plan_groups.size > 0 -%}
                {%- for group in product.selling_plan_groups -%}
                  {%- for plan in group.selling_plans -%}
                    {%- if plan.name contains 'month' or plan.name contains 'Month' -%}
                      <input type="hidden" id="wcp-plan-monthly" data-plan-id="{{ plan.id }}">
                    {%- elsif plan.name contains 'year' or plan.name contains 'Year' or plan.name contains 'annual' or plan.name contains 'Annual' -%}
                      <input type="hidden" id="wcp-plan-annual" data-plan-id="{{ plan.id }}">
                    {%- endif -%}
                  {%- endfor -%}
                {%- endfor -%}
                <input type="hidden" name="selling_plan" id="wcp-selling-plan-input" value="">
              {%- endif -%}
              <button type="submit" class="wcp-plan-cta">
                <span>Join {{ tier_name }}</span><span>&rarr;</span>
              </button>
            </form>
          {%- else -%}
            <a id="wcp-subscribe-link" href="{{ section.settings.monthly_url | default: '#' }}" class="wcp-plan-cta">
              <span>Join {{ tier_name }}</span><span>&rarr;</span>
            </a>
          {%- endif -%}
        </div>

        <aside class="wcp-plan-side">
          <div class="wcp-mono" style="color:var(--wcp-ink-mute);margin-bottom:12px;">Also available</div>
          <div class="wcp-plan-side-title">{{ other_tier }}</div>
          <p class="wcp-plan-side-body">{{ section.settings.other_tier_blurb }}</p>
          <div class="wcp-plan-side-price">&euro;{{ other_price }}<small>/ mo &middot; from</small></div>
          <a href="{{ other_tier_url }}" class="wcp-plan-side-link">View {{ other_tier }} &rarr;</a>
        </aside>
      </div>

    </div>
  </section>

  {%- comment -%} ===== HOW IT WORKS ===== {%- endcomment -%}
  {%- if how_blocks.size > 0 -%}
    <section class="wcp-how" id="how">
      <div class="wcp-container">
        <div class="wcp-how-head">
          <div class="wcp-eyebrow" style="margin-bottom:16px;">&sect; 02 &mdash; The routine</div>
          <h2>{{ section.settings.how_headline }}</h2>
        </div>
        <div class="wcp-how-grid" style="grid-template-columns: repeat({{ how_blocks.size }}, 1fr);">
          {%- for block in how_blocks -%}
            <div class="wcp-how-step" {{ block.shopify_attributes }}>
              <div class="wcp-step-n">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
              <h3 class="wcp-step-t">{{ block.settings.title }}</h3>
              <p class="wcp-step-d">{{ block.settings.description }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== JOURNEY ===== {%- endcomment -%}
  {%- if journey_blocks.size > 0 -%}
    <section class="wcp-journey">
      <div class="wcp-container">
        <div class="wcp-journey-head">
          <div>
            <div class="wcp-eyebrow" style="margin-bottom:16px;">&sect; 02&frac12; &mdash; The curriculum</div>
            <h2>{{ section.settings.journey_headline }}</h2>
            <p>{{ section.settings.journey_description }}</p>
          </div>
        </div>
        <div class="wcp-journey-timeline">
          <div class="wcp-journey-line"></div>
          <div class="wcp-curriculum-grid">
            {%- for block in journey_blocks -%}
              {%- assign locked = true -%}
              {%- if forloop.first -%}{%- assign locked = false -%}{%- endif -%}
              <div class="wcp-jbox" {{ block.shopify_attributes }}>
                <div class="wcp-jdot-row">
                  <div class="wcp-jdot{% unless locked %} wcp-jdot--active{% endunless %}"></div>
                  {%- if forloop.first -%}<div class="wcp-jstart">You start here &darr;</div>{%- endif -%}
                </div>
                <div class="wcp-jcard{% if locked %} wcp-jcard--locked{% endif %}">
                  <div class="wcp-jcard__inner">
                    <div class="wcp-jcard-top">
                      <span class="wcp-jbox-n{% if locked %} wcp-jbox-n--locked{% endif %}">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                      <span class="wcp-jbox-mo">{{ block.settings.month_label }}</span>
                    </div>
                    <h3 class="wcp-jbox-title{% if locked %} wcp-jbox-title--locked{% endif %}">
                      {%- if locked -%}Sealed{%- else -%}{{ block.settings.title }}{%- endif -%}
                    </h3>
                    <p class="wcp-jbox-hint">{{ block.settings.hint }}</p>
                    {%- if locked -%}<div class="wcp-jbox-revealed">Revealed on arrival</div>{%- endif -%}
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
        <div class="wcp-journey-foot">
          <div><strong>{{ section.settings.journey_foot_strong }}</strong>&nbsp;&nbsp;{{ section.settings.journey_foot_text }}</div>
          <a href="#plans" class="wcp-mono" style="color:var(--wcp-ink);text-decoration:underline;text-underline-offset:4px;">Start at Box 01 &rarr;</a>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== IN THE BOX ===== {%- endcomment -%}
  {%- if box_blocks.size > 0 -%}
    <section class="wcp-inbox">
      <div class="wcp-container">
        <div class="wcp-inbox-grid">
          <div class="wcp-inbox-sticky">
            <div class="wcp-eyebrow" style="margin-bottom:16px;">&sect; 03 &mdash; What arrives</div>
            <h2>{{ section.settings.inbox_headline }}</h2>
            <p>{{ section.settings.inbox_description }}</p>
            {%- if section.settings.inbox_image != blank -%}
              <div class="wcp-inbox-image">
                {{ section.settings.inbox_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              </div>
            {%- else -%}
              <div class="wcp-inbox-image-ph">Top-down box shot<br>&mdash; contents laid out</div>
            {%- endif -%}
          </div>
          <div>
            {%- for block in box_blocks -%}
              <div class="wcp-inbox-item" {{ block.shopify_attributes }}>
                <div>
                  <div class="wcp-inbox-item-n">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
                  <div class="wcp-inbox-item-tag">{{ block.settings.tag }}</div>
                </div>
                <div>
                  <h3>{{ block.settings.title }}</h3>
                  <p>{{ block.settings.description }}</p>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== COMPARE TABLE ===== {%- endcomment -%}
  {%- if compare_blocks.size > 0 -%}
    <section class="wcp-compare">
      <div class="wcp-container">
        <div class="wcp-compare-head">
          <div class="wcp-eyebrow" style="margin-bottom:16px;">&sect; 04 &mdash; Side by side</div>
          <h2>{{ section.settings.compare_headline }}</h2>
        </div>
        <div class="wcp-compare-table">
          <div class="wcp-compare-th">
            <div class="wcp-compare-th-cell"><span class="wcp-mono">Feature</span></div>
            <div class="wcp-compare-th-cell wcp-compare-th-cell-border">
              <div class="wcp-compare-th-label">Tier I</div>
              <div class="wcp-compare-th-name">Explorer</div>
            </div>
            <div class="wcp-compare-th-cell wcp-compare-th-cell-adv">
              <div class="wcp-compare-th-label wcp-compare-th-label--adv">Tier II &middot; Most chosen</div>
              <div class="wcp-compare-th-name">Advanced</div>
            </div>
          </div>
          {%- for block in compare_blocks -%}
            <div class="wcp-compare-row" {{ block.shopify_attributes }}>
              <div class="wcp-compare-cell wcp-compare-cell-feat">{{ block.settings.label }}</div>
              <div class="wcp-compare-cell wcp-compare-cell-exp">
