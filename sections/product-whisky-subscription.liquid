<script>
(function() {
  var billing = 'monthly';
  var priceMonthly = {{ price_monthly }};
  var priceAnnual  = {{ price_annual }};
  var annualTotal  = {{ annual_total }};

  var monthlyUrl = {{ section.settings.monthly_url | default: '#' | json }};
  var annualUrl  = {{ section.settings.annual_url  | default: '#' | json }};

  var track       = document.getElementById('wcp-billing-track');
  var priceEl     = document.getElementById('wcp-price');
  var noteEl      = document.getElementById('wcp-price-note');
  var fromEl      = document.getElementById('wcp-sticky-from');
  var link1       = document.getElementById('wcp-subscribe-link');
  var link2       = document.getElementById('wcp-subscribe-link-2');
  var stickyLink  = document.getElementById('wcp-sticky-cta');
  var planInput   = document.getElementById('wcp-selling-plan-input');
  var planMonthly = document.getElementById('wcp-plan-monthly');
  var planAnnual  = document.getElementById('wcp-plan-annual');

  function setBilling(b) {
    billing = b;
    var price = b === 'monthly' ? priceMonthly : priceAnnual;

    // Animate price
    if (priceEl) { priceEl.style.opacity = '0'; priceEl.style.transform = 'translateY(-8px)'; }
    setTimeout(function() {
      if (priceEl) { priceEl.textContent = price; priceEl.style.opacity = '1'; priceEl.style.transform = 'translateY(0)'; }
    }, 180);

    if (noteEl) noteEl.textContent = b === 'annual'
      ? 'Billed annually \u00b7 \u20ac' + annualTotal + ' / yr'
      : 'Billed monthly \u00b7 cancel any time';

    if (fromEl) fromEl.textContent = 'From \u20ac' + price + '/mo';

    // Toggle track
    if (track) track.style.left = b === 'monthly' ? '4px' : 'calc(50% + 2px)';

    // Button states
    document.querySelectorAll('.wcp-billing-btn').forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.billing === b);
    });

    // Links (page template fallback)
    var url = b === 'monthly' ? monthlyUrl : annualUrl;
    [link1, link2, stickyLink].forEach(function(el) { if (el) el.href = url; });

    // Selling plan (product template)
    if (planInput) {
      var planEl = b === 'monthly' ? planMonthly : planAnnual;
      if (planEl) planInput.value = planEl.dataset.planId;
    }
  }

  document.querySelectorAll('.wcp-billing-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { setBilling(btn.dataset.billing); });
  });

  // FAQ accordion
  document.querySelectorAll('.wcp-faq-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.wcp-faq-item');
      var wasOpen = item.classList.contains('open');
      document.querySelectorAll('.wcp-faq-item').forEach(function(i) {
        i.classList.remove('open');
        i.querySelector('.wcp-faq-btn').setAttribute('aria-expanded', 'false');
      });
      if (!wasOpen) { item.classList.add('open'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });

  // Sticky CTA
  var sticky = document.getElementById('wcp-sticky');
  function onScroll() {
    var y = window.scrollY;
    var show = y > 700 && y < document.body.scrollHeight - window.innerHeight - 400;
    if (sticky) { sticky.classList.toggle('visible', show); sticky.setAttribute('aria-hidden', show ? 'false' : 'true'); }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Init
  setBilling('monthly');
})();
</script>

