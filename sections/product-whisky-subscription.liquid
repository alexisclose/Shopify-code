                  <span class="{% if v_exp == '•' %}wcp-dot{% else %}wcp-dash{% endif %}">{{ v_exp }}</span>
                {%- else -%}
                  {{ v_exp }}
                {%- endif -%}
              </div>
              <div class="wcp-compare-cell wcp-compare-cell-adv">
                {%- assign v_adv = block.settings.advanced_value -%}
                {%- if v_adv == '•' or v_adv == '-' or v_adv == '—' -%}
                  <span class="{% if v_adv == '•' %}wcp-dot{% else %}wcp-dash{% endif %}">{{ v_adv }}</span>
                {%- else -%}
                  {{ v_adv }}
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ===== TESTIMONIALS ===== {%- endcomment -%}
  {%- if testimonial_blocks.size > 0 -%}
